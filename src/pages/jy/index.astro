---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const articleSlug = Astro.url.searchParams.get("article");
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 31;
const offset = (page - 1) * limit;

interface CheckinPostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: CheckinPostRow[] = [];
let totalPosts = 0;
let detailPost: CheckinPostRow | null = null;

try {
  const db = getDb(env.DB);

  if (articleSlug) {
    const [found] = await db
      .select({
        title: blogPosts.title,
        slug: blogPosts.slug,
        excerpt: blogPosts.excerpt,
        publishedAt: blogPosts.publishedAt,
        featuredImageKey: blogPosts.featuredImageKey,
        content: blogPosts.content,
      })
      .from(blogPosts)
      .where(sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} = ${articleSlug}`)
      .limit(1);
    detailPost = found || null;
  }

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'jy' OR ${blogPosts.slug} LIKE 'jy/%' OR ${blogPosts.slug} LIKE 'jy-%')`);
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'jy' OR ${blogPosts.slug} LIKE 'jy/%' OR ${blogPosts.slug} LIKE 'jy-%')`)
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch (e) {
  console.error("JY checkin page error:", e);
}

const totalPages = Math.ceil(totalPosts / limit);
const startDateStr = "2026-03-21";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

// 生成当月日历数据
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();
const daysInMonth = new Date(year, month + 1, 0).getDate();
const firstDayOfWeek = new Date(year, month, 1).getDay();

// 收集已打卡日期
const checkedDates = new Set<string>();
posts.forEach(p => {
  if (p.publishedAt) {
    const d = new Date(p.publishedAt);
    if (d.getFullYear() === year && d.getMonth() === month) {
      checkedDates.add(String(d.getDate()));
    }
  }
});

const today = now.getDate();
const weekDays = ["日", "一", "二", "三", "四", "五", "六"];

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  return `${date.getMonth() + 1}.${date.getDate()}`;
}

function formatDetailDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日 ${String(date.getHours()).padStart(2, "0")}:${String(date.getMinutes()).padStart(2, "0")}`;
}

// 连续打卡天数
function getStreak(): number {
  let streak = 0;
  const today = new Date();
  for (let i = 0; i < 365; i++) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    const key = `${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`;
    const found = posts.some(p => {
      if (!p.publishedAt) return false;
      const pd = new Date(p.publishedAt);
      return pd.getFullYear() === d.getFullYear() && pd.getMonth() === d.getMonth() && pd.getDate() === d.getDate();
    });
    if (found) streak++;
    else break;
  }
  return streak;
}
const streakDays = getStreak();
const checkinRate = daysInMonth > 0 ? Math.round((checkedDates.size / daysInMonth) * 100) : 0;
---

<Base title="JY打卡" description="每天打卡，记录我们的每一天 💕">
  <div class="jy-page">
    {detailPost ? (
      <!-- 详情页 -->
      <article class="detail-page">
        <header class="detail-hero">
          <div class="detail-hero-badge">📋 打卡详情</div>
          <h1 class="detail-title">{detailPost.title}</h1>
          <div class="detail-meta">
            <span>💑 相恋第 {loveDays} 天</span>
            {detailPost.publishedAt && <span>📅 {formatDetailDate(detailPost.publishedAt)}</span>}
          </div>
        </header>
        {detailPost.featuredImageKey && (
          <div class="detail-image-wrap">
            <img src={`/media/${detailPost.featuredImageKey}`} alt={detailPost.title} class="detail-image" />
          </div>
        )}
        <div class="detail-body">
          <div class="detail-content" set:html={detailPost.content}></div>
        </div>
        <footer class="detail-footer">
          <a href="/jy" class="detail-back-btn">← 返回打卡页面</a>
          <div class="detail-footer-hearts">❤️ 💕 💗 💖</div>
        </footer>
      </article>
    ) : (
      <>
        <!-- 头部统计 -->
        <header class="jy-hero">
          <div class="jy-hero-bg"></div>
          <div class="jy-hero-content">
            <div class="jy-hero-icon-row">
              <span>📅</span>
              <span class="jy-hero-heart">💗</span>
              <span>✅</span>
            </div>
            <h1 class="jy-hero-title">JY 每日打卡</h1>
            <p class="jy-hero-sub">每一天都值得记录</p>
            <div class="jy-hero-stats">
              <div class="jy-stat-card">
                <div class="jy-stat-icon">🔥</div>
                <div class="jy-stat-value">{streakDays}</div>
                <div class="jy-stat-label">连续打卡</div>
              </div>
              <div class="jy-stat-card">
                <div class="jy-stat-icon">📋</div>
                <div class="jy-stat-value">{checkedDates.size}</div>
                <div class="jy-stat-label">本月打卡</div>
              </div>
              <div class="jy-stat-card">
                <div class="jy-stat-icon">💑</div>
                <div class="jy-stat-value">{loveDays}</div>
                <div class="jy-stat-label">相恋天数</div>
              </div>
              <div class="jy-stat-card">
                <div class="jy-stat-icon">🎯</div>
                <div class="jy-stat-value">{checkinRate}%</div>
                <div class="jy-stat-label">打卡率</div>
              </div>
            </div>
            <!-- 进度条 -->
            <div class="jy-progress-wrap">
              <div class="jy-progress-bar">
                <div class="jy-progress-fill" style={`width:${checkinRate}%`}></div>
              </div>
              <span class="jy-progress-text">本月完成 {checkinRate}%</span>
            </div>
          </div>
        </header>

        <!-- 日历区域 -->
        <main class="jy-main">
          <div class="jy-calendar-card">
            <div class="jy-calendar-header">
              <h2 class="jy-calendar-title">
                {year}年 {month + 1}月
              </h2>
              <div class="jy-calendar-legend">
                <span class="jy-legend-item"><span class="jy-legend-dot checked"></span> 已打卡</span>
                <span class="jy-legend-item"><span class="jy-legend-dot today"></span> 今天</span>
              </div>
            </div>

            <div class="jy-calendar-grid">
              {weekDays.map(day => (
                <div class="jy-calendar-weekday">{day}</div>
              ))}

              {Array.from({ length: firstDayOfWeek }, (_, i) => (
                <div class="jy-calendar-day empty"></div>
              ))}

              {Array.from({ length: daysInMonth }, (_, i) => {
                const day = i + 1;
                const isChecked = checkedDates.has(String(day));
                const isToday = day === today;
                const dayPosts = posts.filter(p => {
                  if (!p.publishedAt) return false;
                  const d = new Date(p.publishedAt);
                  return d.getFullYear() === year && d.getMonth() === month && d.getDate() === day;
                });

                return (
                  <div class={`jy-calendar-day ${isChecked ? 'checked' : ''} ${isToday ? 'today' : ''}`}>
                    <span class="jy-day-number">{day}</span>
                    {isChecked && <span class="jy-day-check">✅</span>}
                    {isToday && !isChecked && <span class="jy-day-pending">⏳</span>}
                    {dayPosts.length > 0 && (
                      <a href={`/jy?article=${dayPosts[0].slug}`} class="jy-day-link" title={dayPosts[0].title}>
                        📝
                      </a>
                    )}
                  </div>
                );
              })}
            </div>
          </div>

          <!-- 打卡记录列表 -->
          <div class="jy-records">
            <h3 class="jy-records-title">📋 最近打卡记录</h3>
            {posts.length > 0 ? (
              <div class="jy-records-list">
                {posts.slice(0, 10).map((post, i) => (
                  <a href={`/jy?article=${post.slug}`} class="jy-record-item">
                    <span class="jy-record-date">📅 {formatDate(post.publishedAt)}</span>
                    <span class="jy-record-title">{post.title}</span>
                    <span class="jy-record-arrow">→</span>
                  </a>
                ))}
              </div>
            ) : (
              <div class="jy-empty">
                <span>📭</span>
                <p>还没有打卡记录，快去后台发布第一篇吧~</p>
              </div>
            )}

            {totalPages > 1 && (
              <div class="jy-pagination">
                {page > 1 && <a href={`/jy?page=${page - 1}`} class="jy-page-btn">← 上一页</a>}
                <span class="jy-page-info">{page} / {totalPages}</span>
                {page < totalPages && <a href={`/jy?page=${page + 1}`} class="jy-page-btn">下一页 →</a>}
              </div>
            )}
          </div>
        </main>

        <footer class="jy-footer">
          <p>💌 坚持打卡，记录我们的每一天</p>
          <p class="jy-footer-sub">JY先生 ❤️ JX女士</p>
        </footer>
      </>
    )}
  </div>
  <div id="heartContainer"></div>
</Base>

<style is:global>
  :root {
    --jy-pink: #ff6b9d;
    --jy-pink-light: #ffb6ce;
    --jy-purple: #c4a0ff;
    --jy-bg: #fff5f7;
    --jy-white: #ffffff;
    --jy-text: #4a3040;
    --jy-text-light: #b090a0;
    --jy-shadow: 0 4px 20px rgba(255, 107, 157, 0.08);
    --jy-shadow-lg: 0 12px 40px rgba(255, 107, 157, 0.12);
  }

  .jy-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #fff5f7 0%, #ffffff 30%, #fff8fa 100%);
    color: var(--jy-text);
    font-family: "Georgia", "Noto Serif SC", serif;
    overflow-x: hidden;
  }

  /* ===== 头部 ===== */
  .jy-hero {
    position: relative;
    padding: 3rem 1.5rem 2rem;
    text-align: center;
    background: radial-gradient(circle at 50% 0%, rgba(255, 182, 206, 0.15) 0%, transparent 60%);
  }

  .jy-hero-icon-row {
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
    animation: jyFloat 3s ease-in-out infinite;
  }

  .jy-hero-heart {
    animation: jyHeartBeat 1.2s ease-in-out infinite;
  }

  @keyframes jyFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes jyHeartBeat {
    0%, 100% { transform: scale(1); }
    14% { transform: scale(1.25); }
    28% { transform: scale(1); }
    42% { transform: scale(1.25); }
    56% { transform: scale(1); }
  }

  .jy-hero-title {
    font-size: 2.4rem;
    font-weight: 800;
    background: linear-gradient(135deg, #ff6b9d, #c4a0ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 0.3rem;
  }

  .jy-hero-sub {
    color: var(--jy-text-light);
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
  }

  .jy-hero-stats {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }

  .jy-stat-card {
    background: var(--jy-white);
    border-radius: 16px;
    padding: 1rem 1.2rem;
    box-shadow: var(--jy-shadow);
    border: 1px solid rgba(255, 182, 206, 0.2);
    text-align: center;
    min-width: 80px;
    transition: all 0.3s ease;
  }

  .jy-stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--jy-shadow-lg);
  }

  .jy-stat-icon { font-size: 1.3rem; margin-bottom: 0.3rem; }
  .jy-stat-value { font-size: 1.6rem; font-weight: 700; color: var(--jy-pink); }
  .jy-stat-label { font-size: 0.72rem; color: var(--jy-text-light); margin-top: 0.2rem; }

  .jy-progress-wrap {
    max-width: 400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .jy-progress-bar {
    flex: 1;
    height: 10px;
    background: rgba(255, 107, 157, 0.1);
    border-radius: 999px;
    overflow: hidden;
  }

  .jy-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #ffb6ce, #ff6b9d);
    border-radius: 999px;
    transition: width 1s ease;
  }

  .jy-progress-text {
    font-size: 0.8rem;
    color: var(--jy-pink);
    font-weight: 600;
    white-space: nowrap;
  }

  /* ===== 日历 ===== */
  .jy-main {
    max-width: 700px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }

  .jy-calendar-card {
    background: var(--jy-white);
    border-radius: 24px;
    padding: 1.5rem;
    box-shadow: var(--jy-shadow);
    border: 1px solid rgba(255, 182, 206, 0.15);
    margin-bottom: 2rem;
  }

  .jy-calendar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .jy-calendar-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--jy-text);
    margin: 0;
  }

  .jy-calendar-legend {
    display: flex;
    gap: 0.8rem;
  }

  .jy-legend-item {
    font-size: 0.75rem;
    color: var(--jy-text-light);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .jy-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .jy-legend-dot.checked {
    background: var(--jy-pink);
    box-shadow: 0 0 8px rgba(255, 107, 157, 0.4);
  }

  .jy-legend-dot.today {
    background: #c4a0ff;
    box-shadow: 0 0 8px rgba(196, 160, 255, 0.4);
  }

  .jy-calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    text-align: center;
  }

  .jy-calendar-weekday {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--jy-text-light);
    padding: 0.5rem 0;
  }

  .jy-calendar-day {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    font-size: 0.9rem;
    position: relative;
    transition: all 0.3s ease;
    cursor: default;
    background: rgba(255, 107, 157, 0.02);
  }

  .jy-calendar-day.empty {
    background: transparent;
  }

  .jy-calendar-day.checked {
    background: rgba(255, 107, 157, 0.08);
    animation: jyPopIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes jyPopIn {
    0% { transform: scale(0); }
    100% { transform: scale(1); }
  }

  .jy-calendar-day.today {
    background: rgba(196, 160, 255, 0.12);
    box-shadow: 0 0 0 2px rgba(196, 160, 255, 0.3);
    font-weight: 700;
  }

  .jy-day-number {
    font-weight: 500;
    color: var(--jy-text);
  }

  .jy-day-check {
    font-size: 0.7rem;
    position: absolute;
    top: 2px;
    right: 4px;
  }

  .jy-day-pending {
    font-size: 0.8rem;
    animation: jyFloat 2s ease-in-out infinite;
  }

  .jy-day-link {
    font-size: 0.6rem;
    text-decoration: none;
    position: absolute;
    bottom: 2px;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .jy-day-link:hover {
    opacity: 1;
  }

  /* ===== 打卡记录 ===== */
  .jy-records {
    background: var(--jy-white);
    border-radius: 24px;
    padding: 1.5rem;
    box-shadow: var(--jy-shadow);
    border: 1px solid rgba(255, 182, 206, 0.15);
  }

  .jy-records-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--jy-text);
    margin: 0 0 1rem;
  }

  .jy-records-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .jy-record-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    background: rgba(255, 107, 157, 0.02);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  .jy-record-item:hover {
    background: rgba(255, 107, 157, 0.05);
    border-color: rgba(255, 107, 157, 0.15);
    transform: translateX(4px);
  }

  .jy-record-date {
    font-size: 0.8rem;
    color: var(--jy-text-light);
    white-space: nowrap;
  }

  .jy-record-title {
    flex: 1;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .jy-record-arrow {
    color: var(--jy-pink);
    transition: transform 0.3s ease;
  }

  .jy-record-item:hover .jy-record-arrow {
    transform: translateX(4px);
  }

  .jy-empty {
    text-align: center;
    padding: 2rem;
    color: var(--jy-text-light);
  }

  .jy-empty span { font-size: 2rem; display: block; margin-bottom: 0.5rem; }

  /* ===== 分页 ===== */
  .jy-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding-top: 1.5rem;
  }

  .jy-page-btn {
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 107, 157, 0.2);
    border-radius: 8px;
    color: var(--jy-pink);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .jy-page-btn:hover {
    background: rgba(255, 107, 157, 0.04);
    border-color: var(--jy-pink);
  }

  .jy-page-info { font-size: 0.85rem; color: var(--jy-text-light); }

  /* ===== 底部 ===== */
  .jy-footer {
    text-align: center;
    padding: 2rem 1rem 3rem;
    color: var(--jy-text-light);
  }

  .jy-footer-sub {
    font-size: 0.85rem;
    color: var(--jy-pink);
    font-weight: 600;
  }

  /* ===== 详情页 ===== */
  .detail-page { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 4rem; }
  .detail-hero { text-align: center; margin-bottom: 2rem; }
  .detail-hero-badge { display: inline-block; padding: 0.35rem 1rem; background: rgba(255,107,157,0.06); border: 1px solid rgba(255,107,157,0.15); border-radius: 999px; font-size: 0.82rem; color: var(--jy-pink); margin-bottom: 1rem; }
  .detail-title { font-size: 2rem; font-weight: 700; color: var(--jy-text); margin: 0 0 0.6rem; line-height: 1.3; }
  .detail-meta { display: flex; gap: 1.2rem; justify-content: center; font-size: 0.85rem; color: var(--jy-text-light); }
  .detail-image-wrap { margin-bottom: 2rem; border-radius: 16px; overflow: hidden; box-shadow: var(--jy-shadow); }
  .detail-image { width: 100%; display: block; }
  .detail-body { margin-bottom: 2rem; }
  .detail-content { font-size: 1.02rem; color: #5a4050; line-height: 1.9; }
  .detail-content :global(h2),.detail-content :global(h3){color:var(--jy-pink);margin-top:1.6rem;margin-bottom:.6rem}
  .detail-content :global(p){margin:0 0 1rem}
  .detail-content :global(img){max-width:100%;border-radius:12px;margin:1rem 0}
  .detail-content :global(blockquote){border-left:3px solid var(--jy-pink);margin:1.2rem 0;padding:.6rem 1.2rem;background:rgba(255,107,157,.03);border-radius:0 8px 8px 0;color:var(--jy-text-light);font-style:italic}
  .detail-footer { text-align: center; padding-top: 2rem; border-top: 1px solid rgba(255,182,206,.3); }
  .detail-back-btn { display: inline-flex; padding: .6rem 1.4rem; border: 1px solid rgba(255,107,157,.2); border-radius: 999px; color: var(--jy-pink); text-decoration: none; font-size: .9rem; transition: all .3s; margin-bottom: 1rem; }
  .detail-back-btn:hover { background: rgba(255,107,157,.04); border-color: var(--jy-pink); }
  .detail-footer-hearts { color: var(--jy-pink); letter-spacing: .3rem; }

  /* ===== 特效 ===== */
  .fall-heart {
    position: fixed; top: -10%; color: #ffb6ce; font-size: 16px;
    animation: fall 7s linear infinite; opacity: 0.5; pointer-events: none; z-index: 999;
  }
  .click-float-heart {
    position: absolute; color: #ff6b9d; font-size: 26px;
    pointer-events: none; animation: floatUp 1s ease-out forwards; z-index: 999;
  }
  .spark-particle {
    position: absolute; pointer-events: none; z-index: 998;
    animation: sparkBurst 0.7s ease-out forwards;
  }

  @keyframes fall {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
    100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
  }
  @keyframes floatUp {
    0% { transform: translateY(0) scale(0.8); opacity: 1; }
    100% { transform: translateY(-160px) scale(1.2); opacity: 0; }
  }
  @keyframes sparkBurst {
    0% { transform: translate(0,0) scale(1); opacity: 1; }
    100% { transform: translate(var(--sx), var(--sy)) scale(0); opacity: 0; }
  }

  @media (max-width: 768px) {
    .jy-hero-title { font-size: 1.8rem; }
    .jy-hero-stats { gap: 0.6rem; }
    .jy-stat-card { padding: 0.7rem 0.9rem; min-width: 65px; }
    .jy-stat-value { font-size: 1.3rem; }
    .jy-calendar-card { padding: 1rem; }
    .jy-calendar-day { font-size: 0.78rem; border-radius: 8px; }
  }
</style>

<script>
  const heartContainer = document.getElementById("heartContainer");

  // ===== 爱心飘落 =====
  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = ["❤️","💕","💗","💖","🩷","🌸","✨","💝"][Math.floor(Math.random()*8)];
    heart.style.left = Math.random()*100 + "vw";
    heart.style.animationDuration = Math.random()*5+5 + "s";
    heart.style.fontSize = Math.random()*12+12 + "px";
    heartContainer?.appendChild(heart);
    setTimeout(() => heart.remove(), 9000);
  }
  setInterval(createFallHeart, 600);
  for(let i=0;i<6;i++) setTimeout(createFallHeart, i*400);

  // ===== 点击爱心 =====
  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "💕";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    heartContainer?.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  // ===== 双击爱心爆炸 =====
  document.body.addEventListener("dblclick", (e) => {
    const emojis = ["💗","💖","💕","💝","🩷","🌸","✨","💘"];
    for(let i=0;i<12;i++){
      setTimeout(()=>{
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = emojis[Math.floor(Math.random()*emojis.length)];
        heart.style.fontSize = Math.random()*24+22 + "px";
        heart.style.left = e.pageX + (Math.random()*90-45) + "px";
        heart.style.top = e.pageY + "px";
        heartContainer?.appendChild(heart);
        setTimeout(()=>heart.remove(),1400);
      }, i*60);
    }
  });

  // ===== 鼠标粒子 =====
  let lastSpark = 0;
  document.body.addEventListener("mousemove", (e) => {
    const now = Date.now();
    if(now - lastSpark < 100) return;
    lastSpark = now;
    const spark = document.createElement("div");
    spark.className = "spark-particle";
    spark.innerHTML = ["✨","💕","🌸","🩷"][Math.floor(Math.random()*4)];
    spark.style.left = e.pageX + "px";
    spark.style.top = e.pageY + "px";
    spark.style.fontSize = Math.random()*10+8 + "px";
    spark.style.setProperty("--sx", (Math.random()*50-25)+"px");
    spark.style.setProperty("--sy", (Math.random()*-50-10)+"px");
    heartContainer?.appendChild(spark);
    setTimeout(() => spark.remove(), 700);
  });

  // ===== 日历日期点击特效 =====
  document.querySelectorAll(".jy-calendar-day.checked").forEach(day => {
    day.addEventListener("click", function(e) {
      e.stopPropagation();
      const rect = this.getBoundingClientRect();
      const cx = rect.left + rect.width/2;
      const cy = rect.top + rect.height/2;
      for(let i=0;i<6;i++){
        const spark = document.createElement("div");
        spark.className = "spark-particle";
        spark.innerHTML = ["💕","✨","💖"][Math.floor(Math.random()*3)];
        spark.style.left = cx + "px";
        spark.style.top = cy + "px";
        spark.style.fontSize = "16px";
        spark.style.setProperty("--sx", (Math.random()*60-30)+"px");
        spark.style.setProperty("--sy", (Math.random()*-60-10)+"px");
        heartContainer?.appendChild(spark);
        setTimeout(()=>spark.remove(), 700);
      }
    });
  });
</script>