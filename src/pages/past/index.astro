    .vinyl-player { flex-direction: column; text-align: center; max-width: 280px; }
    .capsule-trigger { bottom: 1.5rem; right: 1rem; width: 48px; height: 48px; }
    .capsule-trigger-icon { font-size: 1.4rem; }
  }
</style>

<script>
  // ===== 樱花飘落引擎 =====
  const canvas = document.getElementById("sakuraCanvas") as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext("2d");
    if (!ctx) throw new Error("Canvas not supported");
    let width = (canvas.width = window.innerWidth);
    let height = (canvas.height = window.innerHeight);
    window.addEventListener("resize", () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
    });

    interface Petal {
      x: number; y: number; size: number; speedX: number; speedY: number;
      rotation: number; rotationSpeed: number; opacity: number; type: number;
      wobble: number; wobbleSpeed: number;
    }
    const petals: Petal[] = [];
    for (let i = 0; i < 45; i++) {
      petals.push({
        x: Math.random() * width, y: Math.random() * height - height,
        size: Math.random() * 14 + 8, speedX: Math.random() * 1.5 - 0.5,
        speedY: Math.random() * 1.2 + 0.6, rotation: Math.random() * 360,
        rotationSpeed: Math.random() * 2 - 1, opacity: Math.random() * 0.5 + 0.3,
        type: Math.floor(Math.random() * 3), wobble: Math.random() * Math.PI * 2,
        wobbleSpeed: Math.random() * 0.02 + 0.01,
      });
    }

    function drawPetal(ctx: CanvasRenderingContext2D, x: number, y: number, size: number, rotation: number, opacity: number, type: number) {
      ctx.save(); ctx.translate(x, y); ctx.rotate((rotation * Math.PI) / 180); ctx.globalAlpha = opacity;
      const colors = [["#ffb6ce","#ffd4e0"],["#ffe4ea","#fff0f3"],["#ffc4d8","#ffdde8"]];
      const [c1, c2] = colors[type] || colors[0];
      ctx.beginPath();
      const w = size * 0.5, h = size * 0.7;
      ctx.ellipse(-w * 0.25, 0, w, h, 0, 0, Math.PI * 2);
      ctx.ellipse(w * 0.25, 0, w, h, 0, 0, Math.PI * 2);
      const grad = ctx.createRadialGradient(0, 0, size * 0.1, 0, 0, size * 0.6);
      grad.addColorStop(0, c2); grad.addColorStop(0.6, c1); grad.addColorStop(1, "transparent");
      ctx.fillStyle = grad; ctx.fill();
      ctx.restore();
    }

    function animate() {
      ctx!.clearRect(0, 0, width, height);
      for (const p of petals) {
        p.wobble += p.wobbleSpeed;
        p.x += p.speedX + Math.sin(p.wobble) * 0.12;
        p.y += p.speedY;
        p.rotation += p.rotationSpeed;
        if (p.y > height + 40) { p.y = -40; p.x = Math.random() * width; }
        if (p.x > width + 40) p.x = -40;
        if (p.x < -40) p.x = width + 40;
        drawPetal(ctx!, p.x, p.y, p.size, p.rotation, p.opacity, p.type);
      }
      requestAnimationFrame(animate);
    }
    animate();
  }

  // ===== 点击花瓣散开 =====
  const pastPage = document.getElementById("pastPage");
  pastPage?.addEventListener("click", (e: MouseEvent) => {
    if ((e.target as HTMLElement).closest("a") || (e.target as HTMLElement).closest("button")) return;
    for (let i = 0; i < 8; i++) {
      const angle = (Math.PI * 2 * i) / 8;
      const dist = 60 + Math.random() * 40;
      const petal = document.createElement("div");
      petal.style.cssText = `position:fixed;left:${e.clientX}px;top:${e.clientY}px;font-size:${Math.random()*12+12}px;pointer-events:none;z-index:999;transition:all .8s cubic-bezier(.25,.8,.25,1);opacity:.8`;
      petal.textContent = ["🌸","🍃","✨","🕊️"][Math.floor(Math.random()*4)];
      document.body.appendChild(petal);
      requestAnimationFrame(() => {
        petal.style.transform = `translate(${Math.cos(angle)*dist}px,${Math.sin(angle)*dist}px) rotate(${Math.random()*180}deg)`;
        petal.style.opacity = "0";
      });
      setTimeout(() => petal.remove(), 900);
    }
  });

  // ===== 时间胶囊 =====
  const capsuleTrigger = document.getElementById("capsuleTrigger");
  const capsuleOverlay = document.getElementById("capsuleOverlay");
  const capsuleContent = document.getElementById("capsuleContent");
  const capsuleClose = document.getElementById("capsuleClose");

  const capsuleMemories: { emoji: string; title: string; date: string; excerpt: string }[] = (() => {
    try {
      return (window as any).__pastPostsData || [];
    } catch { return []; }
  })();

  function openCapsule() {
    if (!capsuleOverlay || !capsuleContent) return;
    const mems = capsuleMemories.length > 0 ? capsuleMemories : [
      { emoji: "🌸", title: "还没有回忆", date: "未来", excerpt: "每一段过往都会成为时间胶囊里的宝藏" }
    ];
    const mem = mems[Math.floor(Math.random() * mems.length)];
    capsuleContent.innerHTML = `
      <span class="capsule-memory-emoji">${mem.emoji}</span>
      <div class="capsule-memory-title">${mem.title}</div>
      <div class="capsule-memory-date">${mem.date}</div>
      <p class="capsule-memory-excerpt">${mem.excerpt}</p>
    `;
    capsuleOverlay.style.display = "flex";
  }

  capsuleTrigger?.addEventListener("click", openCapsule);
  capsuleClose?.addEventListener("click", () => { if (capsuleOverlay) capsuleOverlay.style.display = "none"; });
  capsuleOverlay?.addEventListener("click", (e) => { if (e.target === capsuleOverlay) capsuleOverlay.style.display = "none"; });

  // 把文章数据注入时间胶囊
  (window as any).__pastPostsData = [
    { emoji: "🌸", title: "最初的相遇", date: "2026.03.21", excerpt: "那一天，我们的故事开始了..." },
    { emoji: "💕", title: "第一次约会", date: "回忆中", excerpt: "紧张又甜蜜的那一天，阳光正好" },
    { emoji: "🌙", title: "深夜长谈", date: "某个夜晚", excerpt: "说不完的话，停不下的笑声" },
    { emoji: "🎁", title: "惊喜礼物", date: "特别的日子", excerpt: "你笑得像个孩子，那一刻我想永远记住" },
    { emoji: "🕊️", title: "一起旅行", date: "旅途中的记忆", excerpt: "手牵手走过的每一条街都闪闪发光" },
  ];

  // ===== 回忆瓶 =====
  const memoryBottles = document.getElementById("memoryBottles");
  const bottleOverlay = document.getElementById("bottleOverlay");
  const bottleMessage = document.getElementById("bottleMessage");
  const bottleClose = document.getElementById("bottleClose");

  const bottleData = [
    { emoji: "💌", title: "给你的第一封信", date: "2026.03.21", text: "从那天起，我的世界有了不一样的色彩..." },
    { emoji: "🌹", title: "情人节", date: "甜蜜回忆", text: "那天你送的花，我一直珍藏在心里" },
    { emoji: "🌟", title: "许愿", date: "星空下", text: "一起许下的愿望，正在一个接一个实现" },
    { emoji: "🍃", title: "秋天的约定", date: "某个午后", text: "你说要一起去看遍世界，我一直在等" },
    { emoji: "🎐", title: "风铃的记忆", date: "夏天", text: "风吹过风铃的声音，像你的笑声一样好听" },
  ];

  if (memoryBottles) {
    const positions = [
      { top: "15%", left: "8%" },
      { top: "30%", left: "85%" },
      { top: "55%", left: "5%" },
      { top: "70%", left: "90%" },
      { top: "85%", left: "15%" },
    ];

    positions.forEach((pos, i) => {
      const bottle = document.createElement("div");
      bottle.className = "memory-bottle";
      bottle.style.top = pos.top;
      bottle.style.left = pos.left;
      bottle.style.animationDelay = `${i * 0.7}s`;
      bottle.style.animationDuration = `${4 + Math.random() * 3}s`;
      bottle.innerHTML = `
        <div class="memory-bottle-inner">
          <span class="memory-bottle-cork">🟤</span>
          <span class="memory-bottle-glass">🫙</span>
        </div>
      `;
      bottle.addEventListener("click", (e) => {
        e.stopPropagation();
        const data = bottleData[i % bottleData.length];
        if (bottleMessage) {
          bottleMessage.innerHTML = `
            <span class="bottle-message-emoji">${data.emoji}</span>
            <div class="bottle-message-title">${data.title}</div>
            <div class="bottle-message-date">${data.date}</div>
            <p class="bottle-message-text">${data.text}</p>
          `;
        }
        if (bottleOverlay) bottleOverlay.style.display = "flex";
      });
      memoryBottles.appendChild(bottle);
    });
  }

  bottleClose?.addEventListener("click", () => { if (bottleOverlay) bottleOverlay.style.display = "none"; });
  bottleOverlay?.addEventListener("click", (e) => { if (e.target === bottleOverlay) bottleOverlay.style.display = "none"; });

  // ===== 旧唱片机 =====
  const vinylPlayer = document.getElementById("vinylPlayer");
  const vinylDisc = document.getElementById("vinylDisc");
  const vinylInfo = document.getElementById("vinylInfo");

  let isPlaying = false;
  let quoteIndex = 0;

  vinylPlayer?.addEventListener("click", () => {
    if (isPlaying) {
      vinylDisc?.classList.remove("playing");
      if (vinylInfo) vinylInfo.innerHTML = `<span class="vinyl-info-icon">💿</span><span class="vinyl-info-text">点击唱片播放回忆</span>`;
    } else {
      vinylDisc?.classList.add("playing");
      const quote = vinylQuotes[quoteIndex % vinylQuotes.length];
      if (vinylInfo) vinylInfo.innerHTML = `<span class="vinyl-info-icon">🎵</span><span class="vinyl-info-text">${quote}</span>`;
      quoteIndex++;
    }
    isPlaying = !isPlaying;
  });
</script>