    .float-btn-label { font-size: 0.45rem; }
    .rain-fullscreen-text { font-size: 1.1rem; }
  }
</style>

<script>
  // ===== 银杏叶飘落 =====
  const leafCanvas = document.getElementById("leafCanvas") as HTMLCanvasElement | null;
  if (leafCanvas) {
    const ctx = leafCanvas.getContext("2d");
    if (ctx) {
      let w = (leafCanvas.width = innerWidth);
      let h = (leafCanvas.height = innerHeight);
      addEventListener("resize", () => { w = leafCanvas.width = innerWidth; h = leafCanvas.height = innerHeight; });

      const leaves: { x: number; y: number; s: number; vx: number; vy: number; r: number; rs: number; o: number }[] = [];
      for (let i = 0; i < 25; i++) {
        leaves.push({
          x: Math.random() * w, y: Math.random() * h - h,
          s: Math.random() * 10 + 6, vx: Math.random() * 0.8 - 0.2, vy: Math.random() * 0.6 + 0.4,
          r: Math.random() * 360, rs: Math.random() * 1.2 - 0.5,
          o: Math.random() * 0.35 + 0.2,
        });
      }

      function drawLeaf(ctx2: CanvasRenderingContext2D, x: number, y: number, s: number, r: number, o: number) {
        ctx2.save(); ctx2.translate(x, y); ctx2.rotate((r * Math.PI) / 180); ctx2.globalAlpha = o;
        const g = ctx2.createRadialGradient(0, 0, 0, 0, 0, s * 0.5);
        g.addColorStop(0, "#e8d5a3"); g.addColorStop(0.6, "#d4b870"); g.addColorStop(1, "transparent");
        ctx2.fillStyle = g;
        ctx2.beginPath();
        ctx2.ellipse(0, 0, s * 0.3, s * 0.6, 0, 0, Math.PI * 2);
        ctx2.fill();
        ctx2.restore();
      }

      function anim() {
        ctx!.clearRect(0, 0, w, h);
        for (const l of leaves) {
          l.x += l.vx; l.y += l.vy; l.r += l.rs;
          if (l.y > h + 30) { l.y = -30; l.x = Math.random() * w; }
          if (l.x > w + 30) l.x = -30;
          if (l.x < -30) l.x = w + 30;
          drawLeaf(ctx!, l.x, l.y, l.s, l.r, l.o);
        }
        requestAnimationFrame(anim);
      }
      anim();
    }
  }

  // ===== 点击银杏叶散开 =====
  document.getElementById("pastPage")?.addEventListener("click", (e: MouseEvent) => {
    if ((e.target as HTMLElement).closest("a") || (e.target as HTMLElement).closest("button") || (e.target as HTMLElement).closest(".float-btn")) return;
    for (let i = 0; i < 6; i++) {
      const angle = (Math.PI * 2 * i) / 6;
      const d = 50 + Math.random() * 30;
      const el = document.createElement("div");
      el.style.cssText = `position:fixed;left:${e.clientX}px;top:${e.clientY}px;font-size:${Math.random()*10+10}px;pointer-events:none;z-index:999;transition:all .7s ease-out;opacity:.7`;
      el.textContent = ["🍂","🍁","✨","📷"][Math.floor(Math.random() * 4)];
      document.body.appendChild(el);
      requestAnimationFrame(() => {
        el.style.transform = `translate(${Math.cos(angle)*d}px,${Math.sin(angle)*d}px) rotate(${Math.random()*120}deg)`;
        el.style.opacity = "0";
      });
      setTimeout(() => el.remove(), 800);
    }
  });

  // ===== 格言切换 =====
  const pastQuote = document.getElementById("pastQuote");
  const quotes = [
    "我们各自走了很远的路，才来到彼此面前",
    "没有相遇之前，我们都在成为更好的自己",
    "你走过的路，我走过的路，加起来就是我们的故事",
    "各自发光，然后彼此照亮",
    "从前的我，也在努力走向你",
    "每一段独自走过的时光，都不是浪费",
  ];
  let qi = 0;
  pastQuote?.addEventListener("click", (e) => {
    e.stopPropagation();
    qi = (qi + 1) % quotes.length;
    pastQuote.innerHTML = `"${quotes[qi]}"`;
    pastQuote.style.transform = "scale(1.06)";
    setTimeout(() => { pastQuote.style.transform = "scale(1)"; }, 200);
  });

  // ===== 时间胶囊 =====
  const capsuleTrigger = document.getElementById("capsuleTrigger");
  let capsuleData: { title: string; date: string; excerpt: string }[] = [];
  try { const el = document.getElementById("pastPostsData"); if (el && el.textContent) capsuleData = JSON.parse(el.textContent); } catch {}

  capsuleTrigger?.addEventListener("click", () => {
    const overlay = document.createElement("div");
    overlay.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,0.2);backdrop-filter:blur(4px);z-index:10002;display:flex;align-items:center;justify-content:center";
    const modal = document.createElement("div");
    modal.style.cssText = "background:rgba(252,248,240,0.95);border-radius:20px;padding:1.5rem;max-width:380px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.15)";
    const item = capsuleData.length > 0 ? capsuleData[Math.floor(Math.random() * capsuleData.length)] : null;
    modal.innerHTML = `
      <div style="font-size:2rem;margin-bottom:0.5rem">⏳</div>
      ${item ? `<div style="font-weight:600;color:#3a2a1a;margin-bottom:0.3rem">${item.title}</div><div style="font-size:0.78rem;color:#8a7a6a;margin-bottom:0.5rem">${item.date}</div><p style="font-style:italic;color:#8a7a6a;line-height:1.6">"${item.excerpt}"</p>` : '<p style="color:#8a7a6a;font-style:italic">还没有从前的记录</p>'}
      <button style="margin-top:1rem;padding:0.5rem 1.5rem;border:1px solid rgba(180,150,120,0.3);border-radius:999px;background:rgba(255,255,255,0.4);cursor:pointer;font-family:inherit;color:#3a2a1a">合上胶囊</button>
    `;
    modal.querySelector("button")?.addEventListener("click", () => overlay.remove());
    overlay.addEventListener("click", (ev) => { if (ev.target === overlay) overlay.remove(); });
    overlay.appendChild(modal);
    document.body.appendChild(overlay);
  });

  // ===== JY/JX 计数 =====
  try {
    const el = document.getElementById("pastPostsData");
    if (el && el.textContent) {
      const data = JSON.parse(el.textContent) as { author: string }[];
      const jy = data.filter(d => d.author && d.author.includes("JY")).length;
      const jx = data.filter(d => d.author && d.author.includes("JX")).length;
      const jyEl = document.getElementById("jyCount"), jxEl = document.getElementById("jxCount");
      if (jyEl) jyEl.textContent = String(jy);
      if (jxEl) jxEl.textContent = String(jx);
    }
  } catch {}

  // ==========================================
  // 🪟 全屏雨声窗台
  // ==========================================
  const rainWindowToggle = document.getElementById("rainWindowToggle");
  const rainFullscreen = document.getElementById("rainFullscreen");
  const rainFSDrops = document.getElementById("rainFullscreenDrops");
  const rainFSToggle = document.getElementById("rainFSToggle");
  const rainFSClose = document.getElementById("rainFSClose");
  let fsRainActive = true;
  let fsRainInterval: ReturnType<typeof setInterval> | null = null;

  function createFSRainDrop() {
    if (!rainFSDrops || !fsRainActive) return;
    const drop = document.createElement("div");
    drop.className = "rain-fullscreen-drop";
    drop.style.left = Math.random() * 100 + "%";
    drop.style.height = Math.random() * 40 + 30 + "px";
    drop.style.animationDuration = Math.random() * 0.4 + 0.5 + "s";
    drop.style.animationDelay = Math.random() * 0.2 + "s";
    rainFSDrops.appendChild(drop);
    setTimeout(() => drop.remove(), 1200);
  }

  function startFSRain() {
    if (fsRainInterval) clearInterval(fsRainInterval);
    fsRainInterval = setInterval(createFSRainDrop, 30);
    for (let i = 0; i < 100; i++) setTimeout(createFSRainDrop, i * 18);
  }

  function stopFSRain() {
    if (fsRainInterval) clearInterval(fsRainInterval);
    if (rainFSDrops) rainFSDrops.innerHTML = "";
  }

  rainWindowToggle?.addEventListener("click", () => {
    if (rainFullscreen) rainFullscreen.style.display = "block";
    fsRainActive = true;
    if (rainFSToggle) rainFSToggle.textContent = "⏯️ 暂停雨";
    startFSRain();
  });

  rainFSToggle?.addEventListener("click", () => {
    fsRainActive = !fsRainActive;
    if (fsRainActive) { rainFSToggle.textContent = "⏯️ 暂停雨"; startFSRain(); }
    else { rainFSToggle.textContent = "▶️ 继续下雨"; stopFSRain(); }
  });

  rainFSClose?.addEventListener("click", () => {
    if (rainFullscreen) rainFullscreen.style.display = "none";
    stopFSRain();
  });

  // ==========================================
  // 📯 旧式留声机
  // ==========================================
  const phonoToggle = document.getElementById("phonographToggle");
  const phonoOverlay = document.getElementById("phonoOverlay");
  const phonoDisc = document.querySelector(".phono-disc") as HTMLElement | null;
  const phonoHornInner = document.querySelector(".phono-horn-inner") as HTMLElement | null;
  const phonoCrank = document.getElementById("phonoCrank");
  const phonoNowPlaying = document.getElementById("phonoNowPlaying");
  const phonoClose = document.getElementById("phonoClose");
  let isPhonoPlaying = false;
  const phonoMemories = ["那些独自走过的路，后来都成了故事...", "在遇见你之前，我练习了很久的独处", "每一段从前，都在为相遇做准备", "没有你的日子，都是序章", "各自发光，然后彼此照亮"];
  let phonoIndex = 0;

  phonoToggle?.addEventListener("click", () => { if (phonoOverlay) phonoOverlay.style.display = "flex"; });

  phonoCrank?.addEventListener("click", () => {
    if (isPhonoPlaying) return;
    isPhonoPlaying = true;
    phonoDisc?.classList.add("spinning");
    phonoHornInner?.classList.add("playing");
    const memory = phonoMemories[phonoIndex % phonoMemories.length];
    phonoIndex++;
    if (phonoNowPlaying) phonoNowPlaying.innerHTML = `<span>🎶 正在播放：</span><br><span style="font-style:italic">"${memory}"</span>`;
    setTimeout(() => { isPhonoPlaying = false; phonoDisc?.classList.remove("spinning"); phonoHornInner?.classList.remove("playing"); }, 4000);
  });

  phonoClose?.addEventListener("click", () => { if (phonoOverlay) phonoOverlay.style.display = "none"; isPhonoPlaying = false; phonoDisc?.classList.remove("spinning"); phonoHornInner?.classList.remove("playing"); });
  phonoOverlay?.addEventListener("click", (e) => { if (e.target === phonoOverlay) { phonoOverlay.style.display = "none"; isPhonoPlaying = false; phonoDisc?.classList.remove("spinning"); phonoHornInner?.classList.remove("playing"); } });

  // ==========================================
  // 📺 旧电视
  // ==========================================
  document.querySelectorAll(".past-card").forEach((card) => {
    card.addEventListener("dblclick", (e) => {
      e.preventDefault();
      const title = (card.querySelector(".past-card-title") as HTMLElement)?.textContent || "无题";
      const date = (card.querySelector(".past-card-date") as HTMLElement)?.textContent || "";
      const excerpt = (card.querySelector(".past-card-excerpt") as HTMLElement)?.textContent || "";
      const overlay = document.createElement("div"); overlay.className = "tv-overlay";
      const screen = document.createElement("div"); screen.className = "tv-screen";
      const staticDiv = document.createElement("div"); staticDiv.className = "tv-static";
      const reveal = document.createElement("div"); reveal.className = "tv-reveal"; reveal.style.display = "none";
      reveal.innerHTML = `<div class="tv-reveal-title">${title}</div><div class="tv-reveal-date">${date}</div><p class="tv-reveal-text">"${excerpt}"</p>`;
      staticDiv.appendChild(reveal); screen.appendChild(staticDiv);
      const knobRow = document.createElement("div"); knobRow.className = "tv-knob-row";
      const knob = document.createElement("div"); knob.className = "tv-knob"; knob.textContent = "📺";
      knob.addEventListener("click", () => { if (reveal.style.display === "none") { staticDiv.style.animation = "none"; reveal.style.display = "flex"; } else { staticDiv.style.animation = "tvStatic 0.1s infinite"; reveal.style.display = "none"; } });
      const light = document.createElement("div"); light.className = "tv-power-light";
      knobRow.appendChild(knob); knobRow.appendChild(light); screen.appendChild(knobRow);
      const closeBtn = document.createElement("button"); closeBtn.className = "tv-close"; closeBtn.textContent = "关掉电视"; closeBtn.addEventListener("click", () => overlay.remove());
      screen.appendChild(closeBtn); overlay.appendChild(screen);
      overlay.addEventListener("click", (ev) => { if (ev.target === overlay) overlay.remove(); });
      document.body.appendChild(overlay);
    });
  });

  // ==========================================
  // 🏜️ 沙画
  // ==========================================
  const sandToggle = document.getElementById("sandToggle");
  const sandCanvas = document.getElementById("sandCanvas") as HTMLCanvasElement | null;
  const sandHint = document.getElementById("sandHint");
  let sandOn = false, sandCtx: CanvasRenderingContext2D | null = null, sandDrawing = false, sandPoints: { x: number; y: number }[] = [];

  sandToggle?.addEventListener("click", () => {
    sandOn = !sandOn;
    if (sandOn) {
      sandToggle.style.background = "rgba(200,170,120,0.3)"; sandCanvas?.classList.add("active"); if (sandHint) sandHint.classList.add("active");
      if (sandCanvas) { sandCanvas.width = innerWidth; sandCanvas.height = innerHeight; sandCtx = sandCanvas.getContext("2d"); if (sandCtx) { sandCtx.fillStyle = "rgba(200, 170, 120, 0.12)"; sandCtx.fillRect(0, 0, sandCanvas.width, sandCanvas.height); } }
      document.body.style.cursor = "crosshair";
    } else {
      sandToggle.style.background = ""; sandCanvas?.classList.remove("active"); if (sandHint) sandHint.classList.remove("active");
      document.body.style.cursor = ""; sandPoints = [];
    }
  });
  sandCanvas?.addEventListener("mousedown", (e) => { if (!sandOn || !sandCtx) return; sandDrawing = true; sandPoints = [{ x: e.clientX, y: e.clientY }]; });
  sandCanvas?.addEventListener("mousemove", (e) => {
    if (!sandOn || !sandDrawing || !sandCtx) return;
    sandPoints.push({ x: e.clientX, y: e.clientY });
    sandCtx.strokeStyle = "rgba(180, 140, 100, 0.5)"; sandCtx.lineWidth = 8; sandCtx.lineCap = "round"; sandCtx.lineJoin = "round";
    sandCtx.beginPath(); sandCtx.moveTo(sandPoints[sandPoints.length - 2]?.x || e.clientX, sandPoints[sandPoints.length - 2]?.y || e.clientY); sandCtx.lineTo(e.clientX, e.clientY); sandCtx.stroke();
    if (sandPoints.length > 60) { sandCtx.fillStyle = "rgba(200, 170, 120, 0.02)"; sandCtx.fillRect(0, 0, sandCanvas!.width, sandCanvas!.height); }
  });
  sandCanvas?.addEventListener("mouseup", () => {
    sandDrawing = false;
    if (sandCtx && sandCanvas) { const fadeOut = setInterval(() => { if (!sandOn || sandDrawing) { clearInterval(fadeOut); return; } sandCtx!.fillStyle = "rgba(200, 170, 120, 0.015)"; sandCtx!.fillRect(0, 0, sandCanvas!.width, sandCanvas!.height); }, 100); setTimeout(() => clearInterval(fadeOut), 5000); }
  });

  // ==========================================
  // ✨ 萤火虫
  // ==========================================
  const fireflyToggle = document.getElementById("fireflyToggle");
  const fireflyCanvas = document.getElementById("fireflyCanvas") as HTMLCanvasElement | null;
  let fireflyOn = false, fireflyCtx: CanvasRenderingContext2D | null = null, fireflyAnimId = 0;
  const fireflies: { x: number; y: number; vx: number; vy: number; r: number; phase: number }[] = [];

  fireflyToggle?.addEventListener("click", () => {
    fireflyOn = !fireflyOn;
    if (fireflyOn) {
      fireflyToggle.style.background = "rgba(255,240,150,0.3)"; fireflyCanvas?.classList.add("active");
      if (fireflyCanvas) { fireflyCanvas.width = innerWidth; fireflyCanvas.height = innerHeight; fireflyCtx = fireflyCanvas.getContext("2d"); fireflies.length = 0;
        for (let i = 0; i < 30; i++) fireflies.push({ x: Math.random() * innerWidth, y: Math.random() * innerHeight, vx: (Math.random() - 0.5) * 0.6, vy: (Math.random() - 0.5) * 0.6, r: Math.random() * 2 + 1, phase: Math.random() * Math.PI * 2 }); animateFireflies(); }
    } else { fireflyToggle.style.background = ""; fireflyCanvas?.classList.remove("active"); cancelAnimationFrame(fireflyAnimId); }
  });
  function animateFireflies() { if (!fireflyOn || !fireflyCtx || !fireflyCanvas) return; const ctx = fireflyCtx; ctx.clearRect(0, 0, fireflyCanvas.width, fireflyCanvas.height); const t = Date.now() / 1000; fireflies.forEach(f => { f.x += f.vx + Math.sin(t * 2 + f.phase) * 0.3; f.y += f.vy + Math.cos(t * 2 + f.phase) * 0.3; if (f.x < 0) f.x = fireflyCanvas!.width; if (f.x > fireflyCanvas!.width) f.x = 0; if (f.y < 0) f.y = fireflyCanvas!.height; if (f.y > fireflyCanvas!.height) f.y = 0; const alpha = 0.3 + Math.sin(t * 3 + f.phase) * 0.3; const glow = ctx.createRadialGradient(f.x, f.y, 0, f.x, f.y, f.r * 6); glow.addColorStop(0, `rgba(255,240,180,${alpha})`); glow.addColorStop(0.5, `rgba(255,220,120,${alpha * 0.4})`); glow.addColorStop(1, "transparent"); ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(f.x, f.y, f.r * 6, 0, Math.PI * 2); ctx.fill(); }); fireflyAnimId = requestAnimationFrame(animateFireflies); }

  // ==========================================
  // 🫧 泡泡
  // ==========================================
  const bubbleToggle = document.getElementById("bubbleToggle");
  const bubbleContainer = document.getElementById("bubbleContainer");
  let bubbleOn = false, bubbleInterval: ReturnType<typeof setInterval> | null = null;
  function createBubble() { if (!bubbleContainer || !bubbleOn) return; const bubble = document.createElement("div"); bubble.className = "bubble"; const size = Math.random() * 30 + 15; bubble.style.width = size + "px"; bubble.style.height = size + "px"; bubble.style.left = Math.random() * 90 + "%"; bubble.style.bottom = "-40px"; bubble.style.animationDuration = Math.random() * 4 + 4 + "s"; bubbleContainer.appendChild(bubble); setTimeout(() => bubble.remove(), 8000); }
  bubbleToggle?.addEventListener("click", () => { bubbleOn = !bubbleOn; if (bubbleOn) { bubbleToggle.style.background = "rgba(200,180,220,0.3)"; bubbleContainer?.classList.add("active"); bubbleInterval = setInterval(createBubble, 400); for (let i = 0; i < 10; i++) setTimeout(createBubble, i * 200); } else { bubbleToggle.style.background = ""; bubbleContainer?.classList.remove("active"); if (bubbleInterval) clearInterval(bubbleInterval); if (bubbleContainer) bubbleContainer.innerHTML = ""; } });
</script>