---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const articleSlug = Astro.url.searchParams.get("article");
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface PastPostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: PastPostRow[] = [];
let totalPosts = 0;
let detailPost: PastPostRow | null = null;

try {
  const db = getDb(env.DB);

  if (articleSlug) {
    const [found] = await db
      .select({
        title: blogPosts.title,
        slug: blogPosts.slug,
        excerpt: blogPosts.excerpt,
        publishedAt: blogPosts.publishedAt,
        featuredImageKey: blogPosts.featuredImageKey,
        content: blogPosts.content,
      })
      .from(blogPosts)
      .where(sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} = ${articleSlug}`)
      .limit(1);
    detailPost = found || null;
  }

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'past' OR ${blogPosts.slug} LIKE 'past/%' OR ${blogPosts.slug} LIKE 'past-%')`);
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'past' OR ${blogPosts.slug} LIKE 'past/%' OR ${blogPosts.slug} LIKE 'past-%')`)
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch (e) {
  console.error("Past page fetch error:", e);
}

const totalPages = Math.ceil(totalPosts / limit);
const startDateStr = "2026-03-21";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

function getPreviewContent(content: string, maxLen = 100): string {
  const text = content.replace(/[#*`\[\]!>\-]/g, "").replace(/\s+/g, " ").trim();
  return text.length > maxLen ? text.slice(0, maxLen) + "…" : text;
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const day = date.getDate();
  return `${year}.${String(month).padStart(2, "0")}.${String(day).padStart(2, "0")}`;
}

function formatDetailDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日`;
}

const memoryIcons = ["🌸", "🍃", "🕊️", "💭", "🌙", "✨", "🫧", "🎐"];
function getMemoryIcon(index: number): string {
  return memoryIcons[index % memoryIcons.length];
}

// 唱片格言
const vinylQuotes = [
  "你是我一生只会遇见一次的惊喜",
  "世间万物，不及你眉眼半分",
  "想和你一起，看遍世间所有浪漫",
  "你是我的今天，也是我的明天",
  "我在人间贩卖黄昏，只为收集世间温柔去见你",
  "有你的每一天，都是情人节",
  "遇见你之后，我的世界有了光",
  "和你在一起，连空气都是甜的",
];
---

<Base title="过往" description="那些温柔的回忆，都在这里 🕊️">
  <div class="past-page" id="pastPage">
    <canvas id="sakuraCanvas" class="sakura-canvas"></canvas>

    {/* ===== 时间胶囊按钮 ===== */}
    <div class="capsule-trigger" id="capsuleTrigger" title="打开时间胶囊">
      <span class="capsule-trigger-icon">⏳</span>
    </div>

    {/* ===== 回忆瓶容器 ===== */}
    <div class="memory-bottles" id="memoryBottles"></div>

    {detailPost ? (
      <article class="past-detail">
        <div class="past-detail-card">
          <header class="past-detail-hero">
            <span class="past-detail-icon">🕊️</span>
            <h1 class="past-detail-title">{detailPost.title}</h1>
            <div class="past-detail-meta">
              <span>💑 相恋 {loveDays} 天</span>
              {detailPost.publishedAt && <span>📅 {formatDetailDate(detailPost.publishedAt)}</span>}
            </div>
          </header>
          {detailPost.featuredImageKey && (
            <div class="past-detail-image-wrap">
              <img src={`/media/${detailPost.featuredImageKey}`} alt={detailPost.title} class="past-detail-image" />
            </div>
          )}
          <div class="past-detail-body">
            <div class="past-detail-content" set:html={detailPost.content}></div>
          </div>
          <footer class="past-detail-footer">
            <a href="/past" class="past-detail-back">← 回到过往</a>
            <div class="past-detail-hearts">🌸 🕊️ 🍃</div>
          </footer>
        </div>
      </article>
    ) : (
      <>
        <header class="past-hero">
          <div class="past-hero-content">
            <div class="past-hero-icon-row">
              <span class="past-floating-icon">🌸</span>
              <span class="past-floating-icon" style="animation-delay:0.5s">🕊️</span>
              <span class="past-floating-icon" style="animation-delay:1s">🍃</span>
            </div>
            <h1 class="past-hero-title">过往</h1>
            <p class="past-hero-subtitle">那些被时光温柔以待的瞬间</p>
            <div class="past-hero-stats">
              <div class="past-stat">
                <span class="past-stat-num">{totalPosts}</span>
                <span class="past-stat-label">回忆碎片</span>
              </div>
              <div class="past-stat-divider"></div>
              <div class="past-stat">
                <span class="past-stat-num">{loveDays}</span>
                <span class="past-stat-label">一起走过</span>
              </div>
            </div>
          </div>
          <div class="past-hero-scroll">
            <span>向下翻阅回忆</span>
            <span class="past-scroll-arrow">↓</span>
          </div>
        </header>

        <main class="past-main">
          {posts.length > 0 ? (
            <div class="past-masonry">
              {posts.map((post, i) => {
                const previewContent = getPreviewContent(post.content);
                const dateStr = formatDate(post.publishedAt);
                const icon = getMemoryIcon(i);

                return (
                  <a href={`/past?article=${post.slug}`} class="past-card-link">
                    <article class="past-card" style={`animation-delay:${i * 0.08}s`}>
                      {post.featuredImageKey ? (
                        <div class="past-card-image-wrap">
                          <img src={`/media/${post.featuredImageKey}`} alt={post.title} class="past-card-image" loading="lazy" />
                          <div class="past-card-image-overlay">
                            <span class="past-card-image-icon">{icon}</span>
                          </div>
                        </div>
                      ) : (
                        <div class="past-card-image-wrap past-card-placeholder">
                          <span class="past-card-placeholder-icon">{icon}</span>
                        </div>
                      )}
                      <div class="past-card-body">
                        <div class="past-card-meta">
                          <span class="past-card-date">{dateStr}</span>
                          <span class="past-card-icon">{icon}</span>
                        </div>
                        <h3 class="past-card-title">{post.title}</h3>
                        <p class="past-card-excerpt">{post.excerpt || previewContent}</p>
                        <span class="past-card-read">展开回忆 →</span>
                      </div>
                    </article>
                  </a>
                );
              })}
            </div>
          ) : (
            <div class="past-empty">
              <span class="past-empty-icon">🍃</span>
              <h3>还没有回忆</h3>
              <p>每一段过往都会在这里安放</p>
              <div class="past-empty-floating">
                <span>🌸</span><span>🕊️</span><span>🍃</span><span>✨</span>
              </div>
            </div>
          )}

          {totalPages > 1 && (
            <div class="past-pagination">
              {page > 1 && <a href={`/past?page=${page - 1}`} class="past-page-btn">← 上一页</a>}
              <span class="past-page-info">{page} / {totalPages}</span>
              {page < totalPages && <a href={`/past?page=${page + 1}`} class="past-page-btn">下一页 →</a>}
            </div>
          )}
        </main>

        {/* ===== 旧唱片 ===== */}
        <div class="vinyl-player" id="vinylPlayer">
          <div class="vinyl-disc" id="vinylDisc">
            <div class="vinyl-label">🎵</div>
            <div class="vinyl-groove"></div>
            <div class="vinyl-groove"></div>
            <div class="vinyl-groove"></div>
          </div>
          <div class="vinyl-tonearm" id="vinylTonearm">
            <div class="vinyl-tonearm-base"></div>
            <div class="vinyl-tonearm-arm"></div>
            <div class="vinyl-tonearm-head"></div>
          </div>
          <div class="vinyl-info" id="vinylInfo">
            <span class="vinyl-info-icon">💿</span>
            <span class="vinyl-info-text">点击唱片播放回忆</span>
          </div>
        </div>

        <footer class="past-footer">
          <p class="past-footer-text">🌸 所有的过往，都是未来的序章</p>
          <p class="past-footer-sub">JY先生 ❤️ JX女士</p>
        </footer>
      </>
    )}
  </div>

  {/* ===== 时间胶囊弹窗 ===== */}
  <div class="capsule-overlay" id="capsuleOverlay" style="display:none">
    <div class="capsule-modal" id="capsuleModal">
      <div class="capsule-lid" id="capsuleLid">
        <span class="capsule-lid-icon">⏳</span>
      </div>
      <div class="capsule-body">
        <div class="capsule-content" id="capsuleContent">
          <span class="capsule-loading">打开中...</span>
        </div>
      </div>
      <button class="capsule-close" id="capsuleClose">关上胶囊</button>
    </div>
  </div>

  {/* ===== 回忆瓶弹窗 ===== */}
  <div class="bottle-overlay" id="bottleOverlay" style="display:none">
    <div class="bottle-modal" id="bottleModal">
      <div class="bottle-cork"></div>
      <div class="bottle-glass">
        <div class="bottle-message" id="bottleMessage"></div>
      </div>
      <button class="bottle-close" id="bottleClose">放回瓶子</button>
    </div>
  </div>
</Base>

<style is:global>
  :root {
    --past-pink: #ffb6ce;
    --past-purple: #c4a0ff;
    --past-teal: #a0d2db;
    --past-white: rgba(255, 255, 255, 0.9);
    --past-glass: rgba(255, 255, 255, 0.25);
    --past-glass-border: rgba(255, 255, 255, 0.35);
    --past-text: #4a3040;
    --past-text-light: #9a8090;
    --past-shadow: 0 8px 32px rgba(0, 0, 0, 0.04);
  }

  .past-page {
    min-height: 100vh;
    position: relative;
    color: var(--past-text);
    font-family: "Georgia", "Noto Serif SC", "KaiTi", serif;
    overflow-x: hidden;
    background: transparent;
  }

  /* ===== 樱花画布 ===== */
  .sakura-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ===== 时间胶囊触发按钮 ===== */
  .capsule-trigger {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    width: 60px;
    height: 60px;
    background: var(--past-glass);
    backdrop-filter: blur(20px);
    border: 1px solid var(--past-glass-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(0,0,0,0.06);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation: capsuleFloat 3s ease-in-out infinite;
  }

  .capsule-trigger:hover {
    transform: scale(1.15);
    box-shadow: 0 16px 48px rgba(0,0,0,0.1);
  }

  .capsule-trigger-icon {
    font-size: 1.8rem;
  }

  @keyframes capsuleFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ===== 时间胶囊弹窗 ===== */
  .capsule-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.15);
    backdrop-filter: blur(6px);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }

  .capsule-modal {
    background: rgba(255, 245, 240, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    width: 90%;
    max-width: 420px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.12);
    animation: modalPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .capsule-lid {
    background: linear-gradient(135deg, #d4a574, #c4956a);
    padding: 1.2rem;
    text-align: center;
    position: relative;
  }

  .capsule-lid-icon {
    font-size: 2.5rem;
    display: block;
    animation: capsuleFloat 2s ease-in-out infinite;
  }

  .capsule-body {
    padding: 1.8rem;
    text-align: center;
    background: linear-gradient(180deg, rgba(212,165,116,0.1) 0%, transparent 30%);
  }

  .capsule-content {
    min-height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
  }

  .capsule-memory-emoji {
    font-size: 3rem;
    animation: capsuleFloat 1.5s ease-in-out infinite;
  }

  .capsule-memory-title {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--past-text);
  }

  .capsule-memory-date {
    font-size: 0.8rem;
    color: var(--past-text-light);
  }

  .capsule-memory-excerpt {
    font-size: 0.9rem;
    color: var(--past-text-light);
    line-height: 1.6;
    font-style: italic;
  }

  .capsule-close {
    width: 100%;
    padding: 0.8rem;
    border: none;
    background: rgba(212,165,116,0.15);
    color: #8b6914;
    font-size: 0.9rem;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.3s;
  }

  .capsule-close:hover {
    background: rgba(212,165,116,0.25);
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modalPop {
    from { transform: scale(0.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* ===== 回忆瓶 ===== */
  .memory-bottles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
  }

  .memory-bottle {
    position: absolute;
    pointer-events: auto;
    cursor: pointer;
    font-size: 2.5rem;
    animation: bottleFloat 5s ease-in-out infinite;
    transition: transform 0.3s ease;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.06));
  }

  .memory-bottle:hover {
    transform: scale(1.3) !important;
    animation-play-state: paused;
  }

  .memory-bottle-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .memory-bottle-cork {
    font-size: 0.6rem;
    margin-bottom: -0.1rem;
  }

  .memory-bottle-glass {
    font-size: 2.2rem;
    opacity: 0.7;
  }

  @keyframes bottleFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-12px) rotate(3deg); }
    75% { transform: translateY(6px) rotate(-3deg); }
  }

  /* ===== 回忆瓶弹窗 ===== */
  .bottle-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.12);
    backdrop-filter: blur(6px);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }

  .bottle-modal {
    background: rgba(230, 245, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 30% 30% 20px 20px / 15% 15% 20px 20px;
    width: 90%;
    max-width: 380px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.1);
    animation: modalPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .bottle-cork {
    height: 20px;
    background: linear-gradient(180deg, #c4956a, #a07850);
    border-radius: 8px 8px 0 0;
    margin: 0 20%;
  }

  .bottle-glass {
    padding: 1.8rem;
    text-align: center;
    min-height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(180deg, rgba(160,210,219,0.1) 0%, rgba(255,255,255,0.5) 50%);
  }

  .bottle-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .bottle-message-emoji {
    font-size: 2.5rem;
    animation: bottleFloat 2s ease-in-out infinite;
  }

  .bottle-message-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--past-text);
  }

  .bottle-message-date {
    font-size: 0.78rem;
    color: var(--past-text-light);
  }

  .bottle-message-text {
    font-size: 0.85rem;
    color: var(--past-text-light);
    line-height: 1.5;
    font-style: italic;
  }

  .bottle-close {
    width: 100%;
    padding: 0.8rem;
    border: none;
    background: rgba(160,210,219,0.2);
    color: #5a8a94;
    font-size: 0.9rem;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.3s;
    border-radius: 0 0 16px 16px;
  }

  .bottle-close:hover {
    background: rgba(160,210,219,0.3);
  }

  /* ===== 旧唱片机 ===== */
  .vinyl-player {
    position: relative;
    z-index: 1;
    max-width: 400px;
    margin: 3rem auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--past-glass);
    backdrop-filter: blur(20px);
    border: 1px solid var(--past-glass-border);
    border-radius: 24px;
    box-shadow: var(--past-shadow);
    cursor: pointer;
    transition: all 0.4s ease;
    user-select: none;
  }

  .vinyl-player:hover {
    box-shadow: 0 16px 48px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .vinyl-disc {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a1a 0%, #333 50%, #1a1a1a 100%);
    position: relative;
    flex-shrink: 0;
    transition: all 0.6s ease;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .vinyl-disc.playing {
    animation: vinylSpin 3s linear infinite;
  }

  @keyframes vinylSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .vinyl-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff6b9d, #c4a0ff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    z-index: 2;
  }

  .vinyl-groove {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.06);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .vinyl-groove:nth-child(2) { width: 75px; height: 75px; }
  .vinyl-groove:nth-child(3) { width: 60px; height: 60px; }
  .vinyl-groove:nth-child(4) { width: 45px; height: 45px; }

  .vinyl-tonearm {
    position: relative;
    flex-shrink: 0;
  }

  .vinyl-tonearm-base {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #666;
  }

  .vinyl-tonearm-arm {
    width: 60px;
    height: 3px;
    background: #888;
    transform: rotate(-30deg);
    transform-origin: left center;
    transition: transform 0.4s ease;
    border-radius: 2px;
  }

  .vinyl-tonearm-head {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #aaa;
    margin-left: -4px;
  }

  .vinyl-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .vinyl-info-icon {
    font-size: 1.2rem;
  }

  .vinyl-info-text {
    font-size: 0.82rem;
    color: var(--past-text-light);
    font-style: italic;
    transition: all 0.3s ease;
  }

  /* ===== 头部 ===== */
  .past-hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .past-hero-content { position: relative; z-index: 1; }
  .past-hero-icon-row { display: flex; align-items: center; justify-content: center; gap: 1.2rem; margin-bottom: 1.2rem; }
  .past-floating-icon { font-size: 2rem; animation: pastFloat 3.5s ease-in-out infinite; display: inline-block; }

  @keyframes pastFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    30% { transform: translateY(-12px) rotate(5deg); }
    60% { transform: translateY(-4px) rotate(-3deg); }
  }

  .past-hero-title { font-size: 3.2rem; font-weight: 300; letter-spacing: 0.15em; color: var(--past-text); margin: 0 0 0.4rem; text-shadow: 0 2px 12px rgba(255,182,206,0.2); }
