  // ==========================================
  // 🧩 记忆碎片拼图
  // ==========================================
  const puzzleTrigger = document.getElementById("puzzleTrigger");
  const puzzleEmojis = ["📷","🎞️","📼","🕰️","📜","🍂","☕","🚂","🏠"];
  let puzzleOpen = false;

  puzzleTrigger?.addEventListener("click", () => {
    if (puzzleOpen) return;
    puzzleOpen = true;

    const overlay = document.createElement("div");
    overlay.className = "puzzle-overlay";

    const board = document.createElement("div");
    board.className = "puzzle-board";

    const title = document.createElement("h3");
    title.textContent = "🧩 记忆碎片拼图";
    title.style.margin = "0 0 0.5rem";
    title.style.color = "var(--past-text)";
    title.style.fontWeight = "400";
    board.appendChild(title);

    const grid = document.createElement("div");
    grid.className = "puzzle-grid";

    // 随机选 6 个 emoji，每个出现 2 次
    const shuffled = [...puzzleEmojis].sort(() => Math.random() - 0.5).slice(0, 6);
    const pairs = [...shuffled, ...shuffled].sort(() => Math.random() - 0.5);
    let selected: HTMLDivElement | null = null;
    let matched = 0;

    pairs.forEach((emoji) => {
      const piece = document.createElement("div");
      piece.className = "puzzle-piece";
      piece.textContent = emoji;
      piece.dataset.emoji = emoji;

      piece.addEventListener("click", () => {
        if (piece.classList.contains("matched") || piece === selected) return;

        if (selected && selected.dataset.emoji === emoji) {
          piece.classList.add("matched");
          selected.classList.add("matched");
          selected.classList.remove("selected");
          piece.classList.remove("selected");
          selected = null;
          matched += 2;
          if (matched === 12) {
            const complete = document.createElement("div");
            complete.className = "puzzle-complete";
            complete.textContent = "✨ 拼图完成！那些从前的碎片，拼成了现在的你 ✨";
            grid.appendChild(complete);
          }
        } else {
          if (selected) selected.classList.remove("selected");
          piece.classList.add("selected");
          selected = piece;
        }
      });

      grid.appendChild(piece);
    });

    board.appendChild(grid);

    const close = document.createElement("button");
    close.className = "puzzle-close";
    close.textContent = "收起拼图";
    close.addEventListener("click", () => { overlay.remove(); puzzleOpen = false; });

    board.appendChild(close);
    overlay.appendChild(board);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) { overlay.remove(); puzzleOpen = false; } });
    document.body.appendChild(overlay);
  });

  // ==========================================
  // 📺 旧电视雪花
  // ==========================================
  // 双击任意卡片打开电视
  document.querySelectorAll(".past-card").forEach((card) => {
    card.addEventListener("dblclick", (e) => {
      e.preventDefault();
      const title = (card.querySelector(".past-card-title") as HTMLElement)?.textContent || "无题";
      const date = (card.querySelector(".past-card-date") as HTMLElement)?.textContent || "";
      const excerpt = (card.querySelector(".past-card-excerpt") as HTMLElement)?.textContent || "";

      const overlay = document.createElement("div");
      overlay.className = "tv-overlay";

      const screen = document.createElement("div");
      screen.className = "tv-screen";

      const staticDiv = document.createElement("div");
      staticDiv.className = "tv-static";
      staticDiv.id = "tvStaticArea";

      const reveal = document.createElement("div");
      reveal.className = "tv-reveal";
      reveal.style.display = "none";
      reveal.innerHTML = `
        <div class="tv-reveal-title">${title}</div>
        <div class="tv-reveal-date">${date}</div>
        <p class="tv-reveal-text">"${excerpt}"</p>
      `;

      staticDiv.appendChild(reveal);
      screen.appendChild(staticDiv);

      const knobRow = document.createElement("div");
      knobRow.className = "tv-knob-row";
      const knob = document.createElement("div");
      knob.className = "tv-knob";
      knob.textContent = "📺";
      knob.title = "点击调台";
      knob.addEventListener("click", () => {
        if (reveal.style.display === "none") {
          staticDiv.style.animation = "none";
          reveal.style.display = "flex";
        } else {
          staticDiv.style.animation = "tvStatic 0.1s infinite";
          reveal.style.display = "none";
        }
      });
      const light = document.createElement("div");
      light.className = "tv-power-light";
      knobRow.appendChild(knob);
      knobRow.appendChild(light);
      screen.appendChild(knobRow);

      const closeBtn = document.createElement("button");
      closeBtn.className = "tv-close";
      closeBtn.textContent = "关掉电视";
      closeBtn.addEventListener("click", () => overlay.remove());
      screen.appendChild(closeBtn);

      overlay.appendChild(screen);
      overlay.addEventListener("click", (e) => { if (e.target === overlay) overlay.remove(); });
      document.body.appendChild(overlay);
    });
  });

  // ==========================================
  // 🪔 煤油灯
  // ==========================================
  const lampToggle = document.getElementById("lampToggle");
  const lampArea = document.getElementById("lampArea");
  const lampGlow = document.getElementById("lampGlow");
  let lampOn = false;

  lampToggle?.addEventListener("click", () => {
    lampOn = !lampOn;
    if (lampOn) {
      lampToggle.classList.add("active");
      if (lampArea) lampArea.style.display = "block";
      document.body.style.cursor = "none";
    } else {
      lampToggle.classList.remove("active");
      if (lampArea) lampArea.style.display = "none";
      document.body.style.cursor = "";
    }
  });

  document.addEventListener("mousemove", (e) => {
    if (!lampOn || !lampGlow) return;
    lampGlow.style.left = e.clientX + "px";
    lampGlow.style.top = e.clientY + "px";
  });

  // 点击煤油灯区域关闭
  lampArea?.addEventListener("click", () => {
    lampOn = false;
    lampToggle?.classList.remove("active");
    if (lampArea) lampArea.style.display = "none";
    document.body.style.cursor = "";
  });

  // ==========================================
  // 🏜️ 沙画
  // ==========================================
  const sandToggle = document.getElementById("sandToggle");
  const sandCanvas = document.getElementById("sandCanvas") as HTMLCanvasElement | null;
  const sandHint = document.getElementById("sandHint");
  let sandOn = false;
  let sandCtx: CanvasRenderingContext2D | null = null;
  let sandDrawing = false;
  let sandPoints: { x: number; y: number }[] = [];

  sandToggle?.addEventListener("click", () => {
    sandOn = !sandOn;
    if (sandOn) {
      sandToggle.classList.add("active");
      sandCanvas?.classList.add("active");
      if (sandHint) sandHint.classList.add("active");
      if (sandCanvas) {
        sandCanvas.width = innerWidth;
        sandCanvas.height = innerHeight;
        sandCtx = sandCanvas.getContext("2d");
        if (sandCtx) {
          sandCtx.fillStyle = "rgba(200, 170, 120, 0.15)";
          sandCtx.fillRect(0, 0, sandCanvas.width, sandCanvas.height);
        }
      }
      document.body.style.cursor = "crosshair";
    } else {
      sandToggle.classList.remove("active");
      sandCanvas?.classList.remove("active");
      if (sandHint) sandHint.classList.remove("active");
      document.body.style.cursor = "";
      sandPoints = [];
    }
  });

  sandCanvas?.addEventListener("mousedown", (e) => {
    if (!sandOn || !sandCtx) return;
    sandDrawing = true;
    sandPoints = [{ x: e.clientX, y: e.clientY }];
  });

  sandCanvas?.addEventListener("mousemove", (e) => {
    if (!sandOn || !sandDrawing || !sandCtx) return;
    sandPoints.push({ x: e.clientX, y: e.clientY });
    sandCtx.strokeStyle = "rgba(180, 140, 100, 0.5)";
    sandCtx.lineWidth = 8;
    sandCtx.lineCap = "round";
    sandCtx.lineJoin = "round";
    sandCtx.beginPath();
    sandCtx.moveTo(sandPoints[sandPoints.length - 2]?.x || e.clientX, sandPoints[sandPoints.length - 2]?.y || e.clientY);
    sandCtx.lineTo(e.clientX, e.clientY);
    sandCtx.stroke();

    // 慢慢消散旧的线条
    if (sandPoints.length > 60) {
      sandCtx.fillStyle = "rgba(200, 170, 120, 0.02)";
      sandCtx.fillRect(0, 0, sandCanvas!.width, sandCanvas!.height);
    }
  });

  sandCanvas?.addEventListener("mouseup", () => {
    sandDrawing = false;
    // 松手后缓慢消散
    if (sandCtx && sandCanvas) {
      const fadeOut = setInterval(() => {
        if (!sandOn || sandDrawing) { clearInterval(fadeOut); return; }
        sandCtx!.fillStyle = "rgba(200, 170, 120, 0.015)";
        sandCtx!.fillRect(0, 0, sandCanvas!.width, sandCanvas!.height);
      }, 100);
      setTimeout(() => clearInterval(fadeOut), 5000);
    }
  });