  .past-hero-stats { display: flex; align-items: center; justify-content: center; gap: 1.5rem; }
  .past-stat { text-align: center; background: var(--past-glass); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid var(--past-glass-border); border-radius: 20px; padding: 1rem 1.5rem; transition: all 0.4s ease; }
  .past-stat:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.05); }
