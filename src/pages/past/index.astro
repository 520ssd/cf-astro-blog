---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const articleSlug = Astro.url.searchParams.get("article");
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface PastPostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: PastPostRow[] = [];
let totalPosts = 0;
let detailPost: PastPostRow | null = null;

try {
  const db = getDb(env.DB);

  if (articleSlug) {
    const [result] = await db
      .select({
        title: blogPosts.title,
        slug: blogPosts.slug,
        excerpt: blogPosts.excerpt,
        publishedAt: blogPosts.publishedAt,
        featuredImageKey: blogPosts.featuredImageKey,
        content: blogPosts.content,
      })
      .from(blogPosts)
      .where(sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} = ${articleSlug}`)
      .limit(1);
    detailPost = result || null;
  }

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'past' OR ${blogPosts.slug} LIKE 'past/%' OR ${blogPosts.slug} LIKE 'past-%')`);
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'past' OR ${blogPosts.slug} LIKE 'past/%' OR ${blogPosts.slug} LIKE 'past-%')`)
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch (e) {
  console.error("Past page fetch error:", e);
}

const totalPages = Math.ceil(totalPosts / limit);

function getPreviewContent(content: string, maxLen = 100): string {
  const text = content.replace(/[#*`\[\]!>\-]/g, "").replace(/\s+/g, " ").trim();
  return text.length > maxLen ? text.slice(0, maxLen) + "…" : text;
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, "0")}.${String(date.getDate()).padStart(2, "0")}`;
}

const pastQuotes = [
  "我们各自走了很远的路，才来到彼此面前",
  "没有相遇之前，我们都在成为更好的自己",
  "你走过的路，我走过的路，加起来就是我们的故事",
  "各自发光，然后彼此照亮",
  "从前的我，也在努力走向你",
  "每一段独自走过的时光，都不是浪费",
];
---

<Base title="从前" description="认识你之前，我们各自的故事 📷">
  <div class="past-page" id="pastPage">
    <canvas id="leafCanvas" class="leaf-canvas"></canvas>

    {/* ===== 全屏雨声覆盖层 ===== */}
    <div class="rain-fullscreen" id="rainFullscreen" style="display:none">
      <div class="rain-fullscreen-drops" id="rainFullscreenDrops"></div>
      <div class="rain-fullscreen-text" id="rainFullscreenText">
        <span>☔ 窗外下着雨</span>
        <span>适合安静地回忆从前</span>
      </div>
      <div class="rain-fullscreen-controls">
        <button class="rain-fs-btn" id="rainFSToggle">⏯️ 暂停雨</button>
        <button class="rain-fs-btn" id="rainFSClose">关上窗户</button>
      </div>
    </div>

    {/* ===== 浮动按钮组 ===== */}
    <div class="floating-buttons">
      <div class="float-btn" id="capsuleTrigger" title="时间胶囊">
        <span class="float-btn-icon">⏳</span>
        <span class="float-btn-label">胶囊</span>
      </div>
      <div class="float-btn" id="rainWindowToggle" title="雨声窗台">
        <span class="float-btn-icon">🪟</span>
        <span class="float-btn-label">听雨</span>
      </div>
      <div class="float-btn" id="phonographToggle" title="旧式留声机">
        <span class="float-btn-icon">📯</span>
        <span class="float-btn-label">留声</span>
      </div>
      <div class="float-btn" id="tvToggle" title="老电视">
        <span class="float-btn-icon">📺</span>
        <span class="float-btn-label">电视</span>
      </div>
      <div class="float-btn" id="sandToggle" title="沙画">
        <span class="float-btn-icon">🏜️</span>
        <span class="float-btn-label">沙画</span>
      </div>
      <div class="float-btn" id="fireflyToggle" title="萤火虫">
        <span class="float-btn-icon">✨</span>
        <span class="float-btn-label">萤火</span>
      </div>
      <div class="float-btn" id="bubbleToggle" title="吹泡泡">
        <span class="float-btn-icon">🫧</span>
        <span class="float-btn-label">泡泡</span>
      </div>
    </div>

    {/* ===== 特效画布 ===== */}
    <canvas class="sand-canvas" id="sandCanvas"></canvas>
    <canvas class="firefly-canvas" id="fireflyCanvas"></canvas>
    <div class="bubble-container" id="bubbleContainer"></div>
    <div class="sand-hint" id="sandHint">🖐️ 按住鼠标拖拽画沙，松手后慢慢消散</div>

    {/* ===== 留声机弹窗 ===== */}
    <div class="phono-overlay" id="phonoOverlay" style="display:none">
      <div class="phono-machine">
        <div class="phono-turntable" id="phonoTurntable">
          <div class="phono-disc">
            <div class="phono-disc-label">🎵</div>
            <div class="phono-disc-groove"></div>
            <div class="phono-disc-groove"></div>
          </div>
        </div>
        <div class="phono-horn" id="phonoHorn">
          <div class="phono-horn-inner"></div>
        </div>
        <div class="phono-crank" id="phonoCrank">
          <span>🖐️</span>
        </div>
        <div class="phono-now-playing" id="phonoNowPlaying">
          <span>🎶 点击摇柄播放回忆</span>
        </div>
        <button class="phono-close" id="phonoClose">收起留声机</button>
      </div>
    </div>

    {detailPost ? (
      <article class="past-detail">
        <div class="past-detail-card">
          <header class="past-detail-hero">
            <span class="past-detail-icon">📷</span>
            <h1 class="past-detail-title">{detailPost.title}</h1>
            {detailPost.publishedAt && <span class="past-detail-date">{formatDate(detailPost.publishedAt)}</span>}
          </header>
          {detailPost.featuredImageKey && (
            <div class="past-detail-image-wrap">
              <img src={`/media/${detailPost.featuredImageKey}`} alt={detailPost.title} class="past-detail-image" />
            </div>
          )}
          <div class="past-detail-body">
            <div class="past-detail-content" set:html={detailPost.content}></div>
          </div>
          <footer class="past-detail-footer">
            <a href="/past" class="past-detail-back">← 回到从前</a>
          </footer>
        </div>
      </article>
    ) : (
      <>
        <header class="past-hero">
          <div class="past-hero-content">
            <div class="past-hero-icon-row">
              <span class="past-floating-icon">📷</span>
              <span class="past-floating-icon" style="animation-delay:0.6s">🎞️</span>
              <span class="past-floating-icon" style="animation-delay:1.2s">📼</span>
            </div>
            <h1 class="past-hero-title">从前</h1>
            <p class="past-hero-subtitle">认识你之前，我们各自的故事</p>
            <div class="past-hero-quote" id="pastQuote">"{pastQuotes[0]}"</div>
            <div class="past-hero-stats">
              <div class="past-stat">
                <span class="past-stat-avatar">👦</span>
                <span class="past-stat-label">JY</span>
                <span class="past-stat-num" id="jyCount">0</span>
              </div>
              <div class="past-stat-divider"></div>
              <div class="past-stat">
                <span class="past-stat-avatar">👧</span>
                <span class="past-stat-label">JX</span>
                <span class="past-stat-num" id="jxCount">0</span>
              </div>
            </div>
          </div>
          <div class="past-hero-scroll">
            <span>翻阅从前</span>
            <span class="past-scroll-arrow">↓</span>
          </div>
        </header>

        <main class="past-main">
          {posts.length > 0 ? (
            <div class="past-masonry">
              {posts.map((post, i) => {
                const previewContent = getPreviewContent(post.content);
                const dateStr = formatDate(post.publishedAt);

                return (
                  <a href={`/past?article=${post.slug}`} class="past-card-link">
                    <article class="past-card" style={`animation-delay:${i * 0.1}s`}>
                      {post.featuredImageKey ? (
                        <div class="past-card-image-wrap">
                          <img src={`/media/${post.featuredImageKey}`} alt={post.title} class="past-card-image" loading="lazy" />
                        </div>
                      ) : (
                        <div class="past-card-image-wrap past-card-placeholder">
                          <span class="past-card-placeholder-icon">📷</span>
                        </div>
                      )}
                      <div class="past-card-body">
                        <div class="past-card-meta">
                          <span class="past-card-date">{dateStr}</span>
                          {post.excerpt && <span class="past-card-tag">{post.excerpt}</span>}
                        </div>
                        <h3 class="past-card-title">{post.title}</h3>
                        <p class="past-card-excerpt">{previewContent}</p>
                      </div>
                    </article>
                  </a>
                );
              })}
            </div>
          ) : (
            <div class="past-empty">
              <span class="past-empty-icon">📷</span>
              <h3>还没有记录</h3>
              <p>那些各自成长的时光</p>
              <p>在这里安放</p>
            </div>
          )}

          {totalPages > 1 && (
            <div class="past-pagination">
              {page > 1 && <a href={`/past?page=${page - 1}`} class="past-page-btn">← 上一页</a>}
              <span class="past-page-info">{page} / {totalPages}</span>
              {page < totalPages && <a href={`/past?page=${page + 1}`} class="past-page-btn">下一页 →</a>}
            </div>
          )}
        </main>

        <footer class="past-footer">
          <p class="past-footer-text">各自走了很远的路，才来到彼此面前</p>
        </footer>
      </>
    )}
  </div>
</Base>

<script type="application/json" id="pastPostsData">
  {JSON.stringify(posts.map(p => ({
    title: p.title,
    date: p.publishedAt ? formatDate(p.publishedAt) : "",
    excerpt: p.excerpt || getPreviewContent(p.content, 60),
    author: p.excerpt || ""
  })))}
</script>

<style is:global>
  :root {
    --past-glass: rgba(252, 248, 240, 0.55);
    --past-border: rgba(180, 150, 120, 0.3);
    --past-text: #3a2a1a;
    --past-text-light: #8a7a6a;
    --past-accent: #c4956a;
    --past-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }

  .past-page {
    min-height: 100vh;
    position: relative;
    color: var(--past-text);
    font-family: "Georgia", "Noto Serif SC", "KaiTi", serif;
    overflow-x: hidden;
    background: transparent;
  }

  .leaf-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ===== 全屏雨声 ===== */
  .rain-fullscreen {
    position: fixed;
    inset: 0;
    z-index: 10001;
    background: linear-gradient(180deg, #1a1a2a 0%, #0d0d1a 100%);
    overflow: hidden;
    animation: fadeIn 0.5s ease;
  }

  .rain-fullscreen-drops {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .rain-fullscreen-drop {
    position: absolute;
    width: 2px;
    background: linear-gradient(180deg, transparent 0%, rgba(180,200,220,0.7) 40%, rgba(200,220,240,0.9) 100%);
    animation: fsRainFall linear infinite;
    border-radius: 0 0 2px 2px;
  }

  @keyframes fsRainFall {
    0% { transform: translateY(-10vh); opacity: 0; }
    5% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(110vh); opacity: 0; }
  }

  .rain-fullscreen-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: rgba(220,200,180,0.9);
    font-size: 1.4rem;
    font-style: italic;
    text-shadow: 0 0 30px rgba(200,180,150,0.4);
    animation: rainTextPulse 3s ease-in-out infinite;
    text-align: center;
    pointer-events: none;
  }

  @keyframes rainTextPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .rain-fullscreen-controls {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 1rem;
  }

  .rain-fs-btn {
    padding: 0.6rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    color: #ccc;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.9rem;
    backdrop-filter: blur(8px);
    transition: all 0.3s;
  }

  .rain-fs-btn:hover {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* ===== 浮动按钮组 ===== */
  .floating-buttons {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .float-btn {
    width: 52px;
    height: 52px;
    background: var(--past-glass);
    backdrop-filter: blur(16px);
    border: 1px solid var(--past-border);
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--past-shadow);
    transition: all 0.3s ease;
    animation: btnFloat 3s ease-in-out infinite;
  }
  .float-btn:nth-child(1) { animation-delay: 0s; }
  .float-btn:nth-child(2) { animation-delay: 0.3s; }
  .float-btn:nth-child(3) { animation-delay: 0.6s; }
  .float-btn:nth-child(4) { animation-delay: 0.9s; }
  .float-btn:nth-child(5) { animation-delay: 1.2s; }
  .float-btn:nth-child(6) { animation-delay: 1.5s; }
  .float-btn:nth-child(7) { animation-delay: 1.8s; }

  @keyframes btnFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .float-btn:hover {
    transform: scale(1.15) translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    border-color: var(--past-accent);
  }

  .float-btn-icon { font-size: 1.2rem; line-height: 1; }
  .float-btn-label { font-size: 0.5rem; color: var(--past-text-light); letter-spacing: 0.04em; margin-top: 1px; }

  /* ===== 萤火虫画布 ===== */
  .firefly-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    display: none;
  }
  .firefly-canvas.active { display: block; }

  /* ===== 泡泡容器 ===== */
  .bubble-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    display: none;
  }
  .bubble-container.active { display: block; }

  .bubble {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.6) 0%, rgba(200,180,220,0.3) 40%, rgba(180,160,200,0.1) 100%);
    border: 1px solid rgba(255,255,255,0.4);
    animation: bubbleRise linear forwards;
    pointer-events: none;
  }

  @keyframes bubbleRise {
    0% { transform: translateY(0) scale(0.5); opacity: 0.8; }
    20% { transform: translateY(-20vh) scale(1); opacity: 1; }
    100% { transform: translateY(-110vh) scale(1.2); opacity: 0; }
  }

  /* ===== 沙画 ===== */
  .sand-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9998;
    display: none;
  }
  .sand-canvas.active { display: block; pointer-events: auto; }
  .sand-hint {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    background: rgba(0,0,0,0.6);
    color: #e8d5a3;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.78rem;
    pointer-events: none;
    display: none;
  }
  .sand-hint.active { display: block; }

  /* ===== 留声机 ===== */
  .phono-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(8px);
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }

  .phono-machine {
    width: 90%;
    max-width: 460px;
    background: linear-gradient(180deg, #5a3a2a 0%, #3a2010 100%);
    border-radius: 24px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 24px 80px rgba(0,0,0,0.4);
    border: 3px solid #6a4a3a;
  }

  .phono-turntable {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: radial-gradient(circle, #1a1a1a 30%, #0a0a0a 70%);
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .phono-disc {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: linear-gradient(135deg, #111 0%, #222 50%, #111 100%);
    position: relative;
  }

  .phono-disc.spinning { animation: discSpin 2s linear infinite; }

  @keyframes discSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .phono-disc-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #c4956a, #d4b896);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    z-index: 2;
  }

  .phono-disc-groove {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.04);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .phono-disc-groove:nth-child(2) { width: 90px; height: 90px; }
  .phono-disc-groove:nth-child(3) { width: 70px; height: 70px; }

  .phono-horn { width: 80px; height: 60px; margin: 0 auto 0.5rem; }

  .phono-horn-inner {
    width: 0;
    height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-bottom: 50px solid #c4956a;
    margin: 0 auto;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    transition: all 0.3s ease;
  }

  .phono-horn-inner.playing { animation: hornVibrate 0.3s ease-in-out infinite; }

  @keyframes hornVibrate {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  .phono-crank {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8a6a4a, #6a4a2a);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    margin: 0.5rem auto;
    font-size: 1.2rem;
    transition: all 0.3s ease;
    box-shadow: 0 3px 10px rgba(0,0,0,0.3);
  }

  .phono-crank:hover { transform: scale(1.1); }
  .phono-crank:active { transform: rotate(180deg) scale(0.95); }

  .phono-now-playing {
    padding: 0.5rem;
    color: #d4b896;
    font-size: 0.85rem;
    font-style: italic;
    min-height: 1.5rem;
  }

  .phono-close {
    width: 100%;
    padding: 0.6rem;
    margin-top: 0.8rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    background: rgba(0,0,0,0.3);
    color: #999;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.85rem;
    transition: all 0.3s;
  }

  .phono-close:hover { background: rgba(0,0,0,0.5); color: #ddd; }

  /* ===== 旧电视 ===== */
  .tv-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(8px);
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }
  .tv-screen {
    width: 90%;
    max-width: 440px;
    background: #1a1a1a;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 80px rgba(0,0,0,0.3);
  }
  .tv-static {
    width: 100%;
    height: 220px;
    background: repeating-linear-gradient(0deg, #000, #111 2px, #000 4px);
    animation: tvStatic 0.1s infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
