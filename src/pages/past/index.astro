  /* ===== 分页 ===== */
  .past-pagination { display: flex; align-items: center; justify-content: center; gap: 1rem; padding-top: 2rem; }
  .past-page-btn { padding: .5rem 1rem; border: 1px solid var(--past-glass-border); border-radius: 999px; color: var(--past-text); text-decoration: none; font-size: .85rem; background: var(--past-glass); backdrop-filter: blur(12px); transition: all .3s; }
  .past-page-btn:hover { background: rgba(255,255,255,0.5); transform: translateY(-2px); }
  .past-page-info { font-size: .85rem; color: var(--past-text-light); }

  /* ===== 底部 ===== */
  .past-footer { position: relative; z-index: 1; text-align: center; padding: 3rem 1rem; }
