  .past-stat-label { font-size: 0.78rem; color: var(--past-text-light); letter-spacing: 0.06em; }
  .past-stat-divider { width: 1px; height: 40px; background: rgba(0,0,0,0.06); }
  .past-hero-scroll { position: absolute; bottom: 2rem; display: flex; flex-direction: column; align-items: center; gap: 0.3rem; color: var(--past-text-light); font-size: 0.8rem; animation: pastScrollBounce 2s ease-in-out infinite; }

  @keyframes pastScrollBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ===== 卡片 ===== */
  .past-main { position: relative; z-index: 1; max-width: 1000px; margin: 0 auto 4rem; padding: 0 1.5rem; }
  .past-masonry { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem; }
  .past-card-link { text-decoration: none; color: inherit; display: block; }
  .past-card { background: var(--past-glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid var(--past-glass-border); border-radius: 20px; overflow: hidden; transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1.2); animation: pastCardFade 0.8s ease forwards; opacity: 0; }
  @keyframes pastCardFade { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .past-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,0.06); border-color: rgba(255,182,206,0.5); }
  .past-card-image-wrap { position: relative; width: 100%; height: 200px; overflow: hidden; background: linear-gradient(135deg, rgba(255,182,206,0.1), rgba(196,160,255,0.1)); }
  .past-card-image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
  .past-card:hover .past-card-image { transform: scale(1.06); }
  .past-card-image-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.4s ease; background: rgba(255,255,255,0.3); }
  .past-card:hover .past-card-image-overlay { opacity: 1; }
  .past-card-image-icon { font-size: 2.5rem; animation: pastFloat 2s ease-in-out infinite; }
  .past-card-placeholder { display: flex; align-items: center; justify-content: center; height: 140px; }
  .past-card-placeholder-icon { font-size: 3rem; opacity: 0.5; animation: pastFloat 3s ease-in-out infinite; }
  .past-card-body { padding: 1rem 1.2rem 1.2rem; }
  .past-card-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.4rem; }
  .past-card-date { font-size: 0.75rem; color: var(--past-text-light); letter-spacing: 0.04em; }
  .past-card-icon { font-size: 1rem; }
  .past-card-title { font-size: 1.05rem; font-weight: 500; color: var(--past-text); margin: 0 0 0.4rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .past-card-excerpt { font-size: 0.82rem; color: var(--past-text-light); line-height: 1.6; margin: 0 0 0.6rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .past-card-read { font-size: 0.8rem; color: var(--past-purple); font-weight: 500; transition: all 0.3s ease; }
  .past-card:hover .past-card-read { letter-spacing: 0.06em; }

  /* ===== 详情页 ===== */
  .past-detail { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; padding: 3rem 1.5rem 4rem; }
  .past-detail-card { background: var(--past-glass); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid var(--past-glass-border); border-radius: 24px; padding: 2rem; box-shadow: var(--past-shadow); }
  .past-detail-hero { text-align: center; margin-bottom: 1.5rem; }
  .past-detail-icon { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }
  .past-detail-title { font-size: 1.6rem; font-weight: 500; color: var(--past-text); margin: 0 0 0.5rem; }
  .past-detail-meta { display: flex; gap: 1rem; justify-content: center; font-size: 0.82rem; color: var(--past-text-light); }
  .past-detail-image-wrap { border-radius: 16px; overflow: hidden; margin-bottom: 1.5rem; }
  .past-detail-image { width: 100%; display: block; }
  .past-detail-body { margin-bottom: 1.5rem; }
  .past-detail-content { font-size: 1rem; color: #5a4050; line-height: 1.9; }
  .past-detail-content :global(h2),.past-detail-content :global(h3){color:var(--past-text);font-weight:500;margin-top:1.5rem;margin-bottom:.6rem}
  .past-detail-content :global(p){margin:0 0 1rem}
  .past-detail-content :global(img){max-width:100%;border-radius:12px;margin:1rem 0}
  .past-detail-content :global(blockquote){border-left:3px solid var(--past-pink);margin:1rem 0;padding:.5rem 1rem;background:rgba(255,182,206,0.08);border-radius:0 8px 8px 0;color:var(--past-text-light);font-style:italic}
  .past-detail-footer { text-align: center; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.04); }
  .past-detail-back { display: inline-flex; padding: .5rem 1.2rem; border: 1px solid var(--past-glass-border); border-radius: 999px; color: var(--past-text); text-decoration: none; font-size: .85rem; transition: all .3s; margin-bottom: .8rem; background: rgba(255,255,255,0.3); }
  .past-detail-back:hover { background: rgba(255,255,255,0.6); transform: translateX(-4px); }
  .past-detail-hearts { color: var(--past-pink); letter-spacing: .2rem; }

  /* ===== 空状态 ===== */
  .past-empty { text-align: center; padding: 4rem 1rem; background: var(--past-glass); backdrop-filter: blur(16px); border: 1px solid var(--past-glass-border); border-radius: 24px; }
  .past-empty-icon { font-size: 3rem; display: block; margin-bottom: 1rem; }
  .past-empty h3 { font-size: 1.2rem; font-weight: 400; color: var(--past-text); margin: 0 0 .4rem; }
  .past-empty p { color: var(--past-text-light); margin: 0 0 1rem; font-size: 0.9rem; }
  .past-empty-floating { display: flex; gap: .6rem; justify-content: center; font-size: 1.2rem; }
  .past-empty-floating span { animation: pastFloat 2.5s ease-in-out infinite; }
  .past-empty-floating span:nth-child(2){animation-delay:.4s}
