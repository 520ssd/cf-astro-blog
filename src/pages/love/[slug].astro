---
export const prerender = false;
import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import { blogPosts, blogCategories } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";

const { slug } = Astro.params;
const db = getDb(env.DB);

const post = await db.query.blogPosts.findFirst({
  where: eq(blogPosts.slug, slug),
});

if (!post) return Astro.redirect("/love");

const startDateStr = "2026-03-20";
function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);
---

<Base title={post.title}>
  <section class="love-hero">
    <div class="love-hero-inner">
      <h1>{post.title}</h1>
      <p>犯错存档 · 相恋第 {loveDays} 天</p>
    </div>
  </section>

  {post.featuredImageKey && (
    <div class="love-img">
      <img src={post.featuredImageKey} alt={post.title} />
    </div>
  )}

  <div class="love-content" set:html={post.content}></div>

  <div id="heartContainer"></div>
  <a href="/love" class="back-btn">← 返回犯错记录</a>
</Base>

<style>
  .love-hero {
    padding: 2rem 1rem;
    text-align: center;
  }
  .love-hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .love-hero h1 {
    color: #ff6b9d;
    font-size: 1.8rem;
  }
  .love-hero p {
    color: #888;
  }
  .love-img {
    max-width: 700px;
    margin: 0 auto 2rem;
    border-radius: 20px;
    overflow: hidden;
  }
  .love-img img {
    width: 100%;
    display: block;
  }
  .love-content {
    max-width: 700px;
    margin: 0 auto 4rem;
    padding: 0 1rem;
    color: #eee;
    line-height: 1.7;
  }
  .back-btn {
    display: block;
    text-align: center;
    color: #ff6b9d;
    text-decoration: none;
    margin-bottom: 3rem;
  }

  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ff87a5;
    font-size: 20px;
    animation: fall 4s linear infinite;
    opacity: 0.7;
    pointer-events: none;
    z-index: 99;
  }
  .click-float-heart {
    position: absolute;
    color: #ff5e8c;
    font-size: 26px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }
  @keyframes fall {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.8; }
    100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
  }
  @keyframes floatUp {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-150px); opacity: 0; }
  }
</style>

<script>
  const container = document.getElementById("heartContainer");
  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * 100 + "vw";
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 7000);
  }
  setInterval(createFallHeart, 300);

  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "❤️";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  document.body.addEventListener("dblclick", (e) => {
    for (let i = 0; i < 6; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = "💗";
        heart.style.fontSize = "40px";
        heart.style.left = e.pageX + (Math.random() * 60 - 30) + "px";
        heart.style.top = e.pageY + "px";
        container.appendChild(heart);
        setTimeout(() => heart.remove(), 1200);
      }, i * 100);
    }
  });
</script>