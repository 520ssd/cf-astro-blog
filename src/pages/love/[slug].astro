---
export const prerender = false;

import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";

const { slug } = Astro.params;
const db = getDb(env.DB);

const post = await db.query.blogPosts.findFirst({
  where: eq(blogPosts.slug, slug),
});

if (!post) return Astro.redirect("/love");

const startDateStr = "2026-03-21";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const day = date.getDate();
  const hour = String(date.getHours()).padStart(2, "0");
  const minute = String(date.getMinutes()).padStart(2, "0");
  return `${year}年${month}月${day}日 ${hour}:${minute}`;
}
---

<Base title={post.title} description={post.excerpt?.slice(0, 160) || ""}>
  <article class="love-detail-page">
    <!-- 顶部头部 -->
    <header class="love-detail-hero">
      <div class="love-detail-hero-glow"></div>
      <div class="love-detail-hero-content">
        <div class="love-detail-badge">
          <span>📋 犯错记录</span>
        </div>
        <h1 class="love-detail-title">{post.title}</h1>
        <div class="love-detail-meta">
          <div class="love-detail-meta-item">
            <span class="love-detail-meta-icon">💑</span>
            <span>相恋第 <strong>{loveDays}</strong> 天</span>
          </div>
          {post.publishedAt && (
            <div class="love-detail-meta-item">
              <span class="love-detail-meta-icon">📅</span>
              <span>{formatDate(post.publishedAt)}</span>
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- 封面图 -->
    {post.featuredImageKey && (
      <div class="love-detail-image-wrap">
        <div class="love-detail-image">
          <img
            src={`/media/${post.featuredImageKey}`}
            alt={post.featuredImageAlt || post.title}
            loading="eager"
          />
        </div>
        <div class="love-detail-image-shadow"></div>
      </div>
    )}

    <!-- 正文内容 -->
    <div class="love-detail-body">
      <div class="love-detail-content" set:html={post.content}></div>
    </div>

    <!-- 底部操作 -->
    <footer class="love-detail-footer">
      <a href="/love" class="love-detail-back">
        <span>←</span> 返回犯错记录
      </a>
      <div class="love-detail-footer-hearts">
        <span>❤️</span>
        <span>💗</span>
        <span>💖</span>
      </div>
    </footer>
  </article>

  <div id="heartContainer"></div>
</Base>

<style>
  :root {
    --love-pink: #ff6b9d;
    --love-pink-light: #ffb6ce;
    --love-pink-dark: #e8557d;
    --love-bg: #0d0d1a;
    --love-card-bg: rgba(255, 240, 245, 0.03);
    --love-card-border: rgba(255, 180, 200, 0.08);
    --love-text: #e8e0e8;
    --love-text-muted: #999;
    --love-glow: rgba(255, 107, 157, 0.15);
  }

  .love-detail-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #0d0d1a 0%, #1a1025 30%, #0d0d1a 100%);
    color: var(--love-text);
    overflow-x: hidden;
  }

  /* ===== 顶部 ===== */
  .love-detail-hero {
    position: relative;
    padding: 3.5rem 1.5rem 2.5rem;
    text-align: center;
    overflow: hidden;
  }

  .love-detail-hero-glow {
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(255, 107, 157, 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .love-detail-hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }

  .love-detail-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(255, 107, 157, 0.1);
    border: 1px solid rgba(255, 107, 157, 0.2);
    border-radius: 999px;
    font-size: 0.85rem;
    color: var(--love-pink);
    margin-bottom: 1.2rem;
    letter-spacing: 0.03em;
  }

  .love-detail-title {
    font-size: 2.2rem;
    font-weight: 800;
    background: linear-gradient(135deg, #ff6b9d 0%, #ffb6ce 50%, #ff6b9d 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: loveTitleGradient 4s ease-in-out infinite;
    margin: 0 0 1rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  @keyframes loveTitleGradient {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .love-detail-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .love-detail-meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: #bbb;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .love-detail-meta-icon {
    font-size: 1rem;
  }

  .love-detail-meta-item strong {
    color: var(--love-pink);
    font-weight: 700;
  }

  /* ===== 封面图 ===== */
  .love-detail-image-wrap {
    position: relative;
    max-width: 760px;
    margin: 0 auto 2.5rem;
    padding: 0 1.5rem;
  }

  .love-detail-image {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(255, 107, 157, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .love-detail-image img {
    width: 100%;
    display: block;
    transition: transform 0.6s ease;
  }

  .love-detail-image:hover img {
    transform: scale(1.02);
  }

  .love-detail-image-shadow {
    position: absolute;
    bottom: -20px;
    left: 10%;
    right: 10%;
    height: 40px;
    background: radial-gradient(
      ellipse,
      rgba(255, 107, 157, 0.08) 0%,
      transparent 70%
    );
    filter: blur(10px);
    pointer-events: none;
  }

  /* ===== 正文 ===== */
  .love-detail-body {
    max-width: 760px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }

  .love-detail-content {
    background: rgba(255, 240, 245, 0.02);
    border: 1px solid rgba(255, 180, 200, 0.06);
    border-radius: 20px;
    padding: 2rem 1.8rem;
    color: #d8d0d8;
    line-height: 1.85;
    font-size: 1.02rem;
  }

  /* 正文内部样式覆盖 */
  .love-detail-content :global(h1),
  .love-detail-content :global(h2),
  .love-detail-content :global(h3) {
    color: var(--love-pink);
    margin-top: 1.8rem;
    margin-bottom: 0.8rem;
    font-weight: 700;
  }

  .love-detail-content :global(h2) {
    font-size: 1.4rem;
    border-left: 3px solid var(--love-pink);
    padding-left: 0.8rem;
  }

  .love-detail-content :global(p) {
    margin: 0 0 1rem;
  }

  .love-detail-content :global(a) {
    color: var(--love-pink);
    text-decoration: none;
    border-bottom: 1px dashed rgba(255, 107, 157, 0.3);
    transition: border-color 0.3s ease;
  }

  .love-detail-content :global(a:hover) {
    border-bottom-color: var(--love-pink);
  }

  .love-detail-content :global(blockquote) {
    border-left: 3px solid var(--love-pink);
    margin: 1.2rem 0;
    padding: 0.8rem 1.2rem;
    background: rgba(255, 107, 157, 0.04);
    border-radius: 0 10px 10px 0;
    color: #ccc;
    font-style: italic;
  }

  .love-detail-content :global(ul),
  .love-detail-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0.8rem 0;
  }

  .love-detail-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .love-detail-content :global(code) {
    background: rgba(255, 107, 157, 0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--love-pink-light);
  }

  .love-detail-content :global(img) {
    max-width: 100%;
    border-radius: 12px;
    margin: 1rem 0;
  }

  .love-detail-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 107, 157, 0.2),
      transparent
    );
    margin: 2rem 0;
  }

  /* ===== 底部 ===== */
  .love-detail-footer {
    text-align: center;
    padding: 2rem 1rem 4rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .love-detail-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    border: 1px solid rgba(255, 107, 157, 0.2);
    border-radius: 999px;
    color: var(--love-pink);
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    margin-bottom: 1.5rem;
  }

  .love-detail-back:hover {
    background: rgba(255, 107, 157, 0.08);
    border-color: var(--love-pink);
    transform: translateX(-4px);
  }

  .love-detail-back span {
    transition: transform 0.3s ease;
  }

  .love-detail-back:hover span {
    transform: translateX(-4px);
  }

  .love-detail-footer-hearts {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    font-size: 1.3rem;
    animation: loveFootFloat 2.5s ease-in-out infinite;
  }

  .love-detail-footer-hearts span:nth-child(2) {
    animation-delay: 0.3s;
  }
  .love-detail-footer-hearts span:nth-child(3) {
    animation-delay: 0.6s;
  }

  @keyframes loveFootFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  /* ===== 爱心特效 ===== */
  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ff87a5;
    font-size: 18px;
    animation: fall 5s linear infinite;
    opacity: 0.5;
    pointer-events: none;
    z-index: 999;
  }

  .click-float-heart {
    position: absolute;
    color: #ff5e8c;
    font-size: 28px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }

  @keyframes fall {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.7;
    }
    100% {
      transform: translateY(100vh) rotate(360deg);
      opacity: 0;
    }
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 1;
    }
    100% {
      transform: translateY(-180px) scale(1.2);
      opacity: 0;
    }
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .love-detail-title {
      font-size: 1.6rem;
    }

    .love-detail-hero {
      padding: 2.5rem 1rem 1.8rem;
    }

    .love-detail-content {
      padding: 1.5rem 1.2rem;
      font-size: 0.95rem;
    }

    .love-detail-image {
      border-radius: 14px;
    }

    .love-detail-meta {
      gap: 0.8rem;
    }

    .love-detail-meta-item {
      font-size: 0.8rem;
      padding: 0.4rem 0.8rem;
    }
  }
</style>

<script>
  const container = document.getElementById("heartContainer");

  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = ["❤️", "💕", "💗", "💖", "🩷"][
      Math.floor(Math.random() * 5)
    ];
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = Math.random() * 3 + 3 + "s";
    heart.style.fontSize = Math.random() * 12 + 14 + "px";
    container?.appendChild(heart);
    setTimeout(() => heart.remove(), 7000);
  }

  setInterval(createFallHeart, 400);

  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "❤️";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    container?.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  document.body.addEventListener("dblclick", (e) => {
    const emojis = ["💗", "💖", "💕", "💝", "🩷", "❤️‍🔥"];
    for (let i = 0; i < 8; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML =
          emojis[Math.floor(Math.random() * emojis.length)];
        heart.style.fontSize = Math.random() * 24 + 28 + "px";
        heart.style.left = e.pageX + (Math.random() * 80 - 40) + "px";
        heart.style.top = e.pageY + "px";
        container?.appendChild(heart);
        setTimeout(() => heart.remove(), 1400);
      }, i * 80);
    }
  });
</script>