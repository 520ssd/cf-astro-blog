---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface LovePostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
}

let posts: LovePostRow[] = [];
let totalPosts = 0;

try {
  const db = getDb(env.DB);

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(getPublicPostVisibilityCondition());
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
    })
    .from(blogPosts)
    .where(getPublicPostVisibilityCondition())
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch {}

const totalPages = Math.ceil(totalPosts / limit);

// 相恋纪念日
const startDateStr = "2026-03-20";
function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);
---

<Base title="情侣犯错记录 | 专属记录本" description="情侣专属犯错存档，有错就记、反省到位 ❤️">
  <!-- 顶部欢迎区(一定要有证据！) -->
  <section class="love-header">
    <div class="love-header-inner">
      <h1 class="love-main-title">📝 情侣犯错记录本</h1>
      <p class="love-desc">犯错要有证据，反省必须到位，存档永久保留</p>
      <div class="love-meta-row">
        <div class="love-meta-item">
          <span>相恋天数</span>
          <strong>{loveDays}</strong>
        </div>
        <div class="love-meta-item">
          <span>犯错存档</span>
          <strong>{totalPosts}</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- 犯错记录列表 -->
  <div class="love-list-wrap">
    {posts.length > 0 ? (
      <div class="love-list">
        {posts.map(post => (
          <a href={`/love/${post.slug}`} class="love-card">
            {post.featuredImageKey && (
              <div class="love-card-img">
                <img src={post.featuredImageKey} alt={post.title} loading="lazy" />
              </div>
            )}
            <div class="love-card-body">
              <h3 class="love-card-title">{post.title}</h3>
              <p class="love-card-excerpt">
                {post.excerpt || "查看犯错详情与反省记录"}
              </p>
              <time class="love-card-time">
                {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : ""}
              </time>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="love-empty">
        <p>目前暂无犯错记录，继续保持乖乖表现 💌</p>
      </div>
    )}
  </div>

  <!-- 分页 -->
  {totalPages > 1 && (
    <nav class="love-pagination">
      {page > 1 && (
        <a href={`/love?page=${page - 1}`} class="love-page-btn">上一页</a>
      )}
      <span class="love-page-info">第 {page} 页 / 共 {totalPages} 页</span>
      {page < totalPages && (
        <a href={`/love?page=${page + 1}`} class="love-page-btn">下一页</a>
      )}
    </nav>
  )}

  <!-- 爱心特效容器 -->
  <div id="heartContainer"></div>
</Base>

<style>
  :root {
    --love-pink: #ff6b8b;
    --love-pink-light: #ffe6ee;
    --love-bg-soft: rgba(255, 245, 248, 0.06);
    --love-border: rgba(255, 180, 200, 0.15);
  }

  body {
    background: transparent;
  }

  /* 顶部头部 */
  .love-header {
    padding: 3rem 1rem 2rem;
    text-align: center;
  }
  .love-header-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .love-main-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--love-pink);
    margin: 0 0 0.6rem;
    font-weight: 600;
  }
  .love-desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }
  .love-meta-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .love-meta-item {
    padding: 0.8rem 1.6rem;
    background: var(--love-bg-soft);
    border: 1px solid var(--love-border);
    border-radius: 999px;
  }
  .love-meta-item span {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .love-meta-item strong {
    font-size: 1.4rem;
    color: var(--love-pink);
  }

  /* 列表容器 */
  .love-list-wrap {
    max-width: 900px;
    margin: 0 auto 3rem;
    padding: 0 1rem;
  }
  .love-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* 记录卡片 */
  .love-card {
    display: block;
    background: var(--love-bg-soft);
    border: 1px solid var(--love-border);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }
  .love-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 30px rgba(255, 107, 139, 0.15);
  }
  .love-card-img {
    width: 100%;
    height: 180px;
    overflow: hidden;
  }
  .love-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .love-card:hover .love-card-img img {
    transform: scale(1.05);
  }
  .love-card-body {
    padding: 1.2rem;
  }
  .love-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
    color: var(--color-text);
  }
  .love-card-excerpt {
    margin: 0 0 0.8rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .love-card-time {
    font-size: 0.8rem;
    color: var(--love-pink);
  }

  /* 空状态 */
  .love-empty {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  /* 分页 */
  .love-pagination {
    max-width: 900px;
    margin: 0 auto 4rem;
    padding: 0 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
  }
  .love-page-btn {
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    background: var(--love-bg-soft);
    border: 1px solid var(--love-border);
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .love-page-btn:hover {
    background: var(--love-pink);
    color: #fff;
    border-color: var(--love-pink);
  }
  .love-page-info {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  /* 爱心特效样式 和详情页完全一致 */
  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ff87a5;
    font-size: 20px;
    animation: fall linear infinite;
    opacity: 0.7;
    pointer-events: none;
    z-index: 99;
  }
  .click-float-heart {
    position: absolute;
    color: #ff5e8c;
    font-size: 26px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }
  @keyframes fall {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.8; }
    100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
  }
  @keyframes floatUp {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-150px); opacity: 0; }
  }
</style>

<script>
  // 爱心全套特效保留不变
  const container = document.getElementById("heartContainer");
  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = Math.random() * 3 + 4 + "s";
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 7000);
  }
  setInterval(createFallHeart, 300);

  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "❤️";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  document.body.addEventListener("dblclick", (e) => {
    for(let i = 0; i < 6; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = "💗";
        heart.style.fontSize = "40px";
        heart.style.left = (e.pageX + Math.random() * 60 - 30) + "px";
        heart.style.top = e.pageY + "px";
        container.appendChild(heart);
        setTimeout(() => heart.remove(), 1200);
      }, i * 100);
    }
  });
</script>