---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql, eq } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

// 1. 处理查询参数，判断是否展示详情
const articleSlug = Astro.url.searchParams.get("article");
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface LovePostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: LovePostRow[] = [];
let totalPosts = 0;
let detailPost: LovePostRow | null = null;

try {
  const db = getDb(env.DB);

  if (articleSlug) {
    // 2. 如果有查询参数，就查这篇文章的详情
    const [found] = await db
      .select({
        title: blogPosts.title,
        slug: blogPosts.slug,
        excerpt: blogPosts.excerpt,
        publishedAt: blogPosts.publishedAt,
        featuredImageKey: blogPosts.featuredImageKey,
        content: blogPosts.content,
      })
      .from(blogPosts)
      .where(
        sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} = ${articleSlug}`
      )
      .limit(1);
    detailPost = found || null;
  }
  
  // 3. 不管是不是详情页，都查一下列表
  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} LIKE 'love-%'`
    );
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} LIKE 'love-%'`
    )
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch (e) {
  console.error("Love page data fetch error:", e);
}

const totalPages = Math.ceil(totalPosts / limit);
const startDateStr = "2026-03-21";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

function getPreviewContent(content: string, maxLen = 80): string {
  const text = content.replace(/[#*`\[\]!>\-]/g, "").replace(/\s+/g, " ").trim();
  return text.length > maxLen ? text.slice(0, maxLen) + "…" : text;
}

const levelEmojiMap: Record<string, string> = {
  "轻度": "😤",
  "中度": "😠",
  "重度": "💢",
  "严重": "🔥",
  "非常严重": "💔",
};

function getRegretDisplay(excerpt: string | null): string {
  if (!excerpt || !excerpt.trim()) return "";
  const level = excerpt.trim();
  const emoji = levelEmojiMap[level] || "💔";
  return `${emoji} ${level}`;
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const day = date.getDate();
  const hour = String(date.getHours()).padStart(2, "0");
  const minute = String(date.getMinutes()).padStart(2, "0");
  return `${year}年${month}月${day}日 ${hour}:${minute}`;
}
---

<Base title="情侣犯错记录" description="犯错要留证据，反省必须到位 ❤️">
  <div class="love-page">
    {detailPost ? (
      <!-- ===== 文章详情页 ===== -->
      <article class="love-detail-page">
        <header class="love-detail-hero">
          <div class="love-detail-hero-glow"></div>
          <div class="love-detail-hero-content">
            <div class="love-detail-badge">
              <span>📋 犯错记录</span>
            </div>
            <h1 class="love-detail-title">{detailPost.title}</h1>
            <div class="love-detail-meta">
              <div class="love-detail-meta-item">
                <span class="love-detail-meta-icon">💑</span>
                <span>相恋第 <strong>{loveDays}</strong> 天</span>
              </div>
              {detailPost.publishedAt && (
                <div class="love-detail-meta-item">
                  <span class="love-detail-meta-icon">📅</span>
                  <span>{formatDate(detailPost.publishedAt)}</span>
                </div>
              )}
            </div>
          </div>
        </header>

        {detailPost.featuredImageKey && (
          <div class="love-detail-image-wrap">
            <div class="love-detail-image">
              <img src={`/media/${detailPost.featuredImageKey}`} alt={detailPost.title} loading="eager" />
            </div>
            <div class="love-detail-image-shadow"></div>
          </div>
        )}

        <div class="love-detail-body">
          <div class="love-detail-content" set:html={detailPost.content}></div>
        </div>

        <footer class="love-detail-footer">
          <a href="/love" class="love-detail-back"><span>←</span> 返回犯错记录</a>
          <div class="love-detail-footer-hearts">
            <span>❤️</span><span>💗</span><span>💖</span>
          </div>
        </footer>
      </article>
    ) : (
      <!-- ===== 列表页 ===== -->
      <>
        <header class="love-hero">
          <div class="love-hero-glow"></div>
          <div class="love-hero-content">
            <div class="love-icon-row">
              <span class="love-emoji">📝</span>
              <span class="love-heart-pulse">💗</span>
              <span class="love-emoji">🔍</span>
            </div>
            <h1 class="love-title">情侣犯错记录本</h1>
            <p class="love-subtitle">每一次犯错，都是更懂你的机会</p>
            <div class="love-stats">
              <div class="love-stat-card">
                <div class="love-stat-icon">💑</div>
                <div class="love-stat-value">{loveDays}</div>
                <div class="love-stat-label">相恋天数</div>
              </div>
              <div class="love-stat-divider"></div>
              <div class="love-stat-card">
                <div class="love-stat-icon">📋</div>
                <div class="love-stat-value">{totalPosts}</div>
                <div class="love-stat-label">犯错记录</div>
              </div>
              <div class="love-stat-divider"></div>
              <div class="love-stat-card">
                <div class="love-stat-icon">💪</div>
                <div class="love-stat-value">{totalPosts > 0 ? Math.max(loveDays - totalPosts, 0) : loveDays}</div>
                <div class="love-stat-label">无错天数</div>
              </div>
            </div>
          </div>
        </header>

        <main class="love-main">
          {posts.length > 0 ? (
            <div class="love-timeline">
              {posts.map((post, i) => {
                const previewContent = getPreviewContent(post.content);
                const regretDisplay = getRegretDisplay(post.excerpt);
                const dateObj = new Date(post.publishedAt!);
                const dateStr = `${dateObj.getFullYear()}年${dateObj.getMonth() + 1}月${dateObj.getDate()}日`;
                const timeStr = `${String(dateObj.getHours()).padStart(2, "0")}:${String(dateObj.getMinutes()).padStart(2, "0")}`;
                const isLeft = i % 2 === 0;

                return (
                  <div class={`love-timeline-item ${isLeft ? "is-left" : "is-right"}`}>
                    <div class="love-timeline-dot">
                      <span>💔</span>
                    </div>
                    <div class="love-timeline-card">
                      <!-- 修改了这里的链接 -->
                      <a href={`/love?article=${post.slug}`} class="love-card-link">
                        {post.featuredImageKey && (
                          <div class="love-card-image-wrap">
                            <img src={`/media/${post.featuredImageKey}`} alt={post.title} class="love-card-image" loading="lazy" />
                            <div class="love-card-image-overlay"></div>
                          </div>
                        )}
                        <div class="love-card-content">
                          <div class="love-card-header">
                            <span class="love-card-number">#{String(i + 1).padStart(2, "0")}</span>
                            {regretDisplay && (
                              <span class="love-card-regret">{regretDisplay}</span>
                            )}
                          </div>
                          <h3 class="love-card-title">{post.title}</h3>
                          <p class="love-card-excerpt">{previewContent || "查看详情"}</p>
                          <div class="love-card-footer">
                            <time class="love-card-date">
                              <span class="love-card-date-icon">📅</span>
                              {dateStr}
                            </time>
                            <span class="love-card-time">{timeStr}</span>
                          </div>
                        </div>
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="love-empty">
              <div class="love-empty-icon">🎉</div>
              <h2 class="love-empty-title">太棒了！还没有犯错记录</h2>
              <p class="love-empty-desc">
                继续保持哦～每一次包容和理解，都让我们的爱更坚定
              </p>
              <div class="love-empty-hearts">
                <span>❤️</span><span>💕</span><span>💗</span><span>💖</span><span>❤️</span>
              </div>
            </div>
          )}
          {/* ... 分页代码保持不变 ... */}
        </main>
      </>
    )}
  </div>
  <div id="heartContainer"></div>
</Base>