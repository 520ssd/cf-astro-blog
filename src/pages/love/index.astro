---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql, eq } from "drizzle-orm";
import { blogPosts, blogCategories } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface LovePostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
}

let posts: LovePostRow[] = [];
let totalPosts = 0;

try {
  const db = getDb(env.DB);

  const loveCategory = await db.query.blogCategories.findFirst({
    where: eq(blogCategories.slug, "love"),
  });

  if (loveCategory) {
    const [countRes] = await db
      .select({ count: sql<number>`count(*)` })
      .from(blogPosts)
      .where(
        sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.categoryId} = ${loveCategory.id}`
      );
    totalPosts = countRes?.count ?? 0;

    posts = await db
      .select({
        title: blogPosts.title,
        slug: blogPosts.slug,
        excerpt: blogPosts.excerpt,
        publishedAt: blogPosts.publishedAt,
        featuredImageKey: blogPosts.featuredImageKey,
      })
      .from(blogPosts)
      .where(
        sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.categoryId} = ${loveCategory.id}`
      )
      .orderBy(desc(blogPosts.publishedAt))
      .limit(limit)
      .offset(offset);
  }
} catch {}

const totalPages = Math.ceil(totalPosts / limit);

const startDateStr = "2026-03-20";
function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);
---

<Base title="情侣犯错记录" description="犯错要留证据，反省必须到位 ❤️">
  <section class="love-header">
    <div class="love-header-inner">
      <h1 class="love-main-title">📝 情侣犯错记录本</h1>
      <p class="love-desc">我们专属的甜蜜与反省存档</p>
      <div class="love-meta-row">
        <div class="love-meta-item">
          <span>相恋天数</span>
          <strong>{loveDays}</strong>
        </div>
        <div class="love-meta-item">
          <span>犯错记录</span>
          <strong>{totalPosts}</strong>
        </div>
      </div>
    </div>
  </section>

  <div class="love-list-wrap">
    {posts.length > 0 ? (
      <div class="love-list">
        {posts.map((post) => (
          <a href={`/love/${post.slug}`} class="love-card">
            {post.featuredImageKey && (
              <div class="love-card-img">
                <img src={post.featuredImageKey} alt={post.title} />
              </div>
            )}
            <div class="love-card-body">
              <h3 class="love-card-title">{post.title}</h3>
              <p class="love-card-excerpt">{post.excerpt || "查看详情"}</p>
              <time class="love-card-time">
                {new Date(post.publishedAt!).toLocaleDateString()}
              </time>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="love-empty">
        <p>暂时还没有犯错记录，继续保持 ✅</p>
      </div>
    )}
  </div>

  <div id="heartContainer"></div>
</Base>

<style>
  .love-header {
    padding: 3rem 1rem;
    text-align: center;
  }
  .love-header-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .love-main-title {
    font-size: 2rem;
    color: #ff6b9d;
    margin-bottom: 0.5rem;
  }
  .love-desc {
    color: #888;
    margin-bottom: 1.5rem;
  }
  .love-meta-row {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }
  .love-meta-item {
    background: rgba(255, 182, 206, 0.1);
    padding: 0.8rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 182, 206, 0.2);
  }
  .love-meta-item span {
    font-size: 0.8rem;
    color: #999;
  }
  .love-meta-item strong {
    font-size: 1.2rem;
    color: #ff6b9d;
  }

  .love-list-wrap {
    max-width: 900px;
    margin: 0 auto 4rem;
    padding: 0 1rem;
  }
  .love-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.2rem;
  }
  .love-card {
    background: rgba(255, 240, 245, 0.05);
    border: 1px solid rgba(255, 180, 200, 0.15);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .love-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 25px rgba(255, 107, 157, 0.1);
  }
  .love-card-img {
    width: 100%;
    height: 180px;
  }
  .love-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .love-card-body {
    padding: 1rem;
  }
  .love-card-title {
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 0.4rem;
  }
  .love-card-excerpt {
    font-size: 0.9rem;
    color: #aaa;
    margin: 0 0 0.6rem;
  }
  .love-card-time {
    font-size: 0.8rem;
    color: #ff6b9d;
  }
  .love-empty {
    text-align: center;
    padding: 3rem 1rem;
    color: #888;
  }

  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ff87a5;
    font-size: 20px;
    animation: fall 4s linear infinite;
    opacity: 0.7;
    pointer-events: none;
    z-index: 99;
  }
  .click-float-heart {
    position: absolute;
    color: #ff5e8c;
    font-size: 26px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }
  @keyframes fall {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.8; }
    100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
  }
  @keyframes floatUp {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-150px); opacity: 0; }
  }
</style>

<script>
  const container = document.getElementById("heartContainer");
  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * 100 + "vw";
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 7000);
  }
  setInterval(createFallHeart, 300);

  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "❤️";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  document.body.addEventListener("dblclick", (e) => {
    for (let i = 0; i < 6; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = "💗";
        heart.style.fontSize = "40px";
        heart.style.left = e.pageX + (Math.random() * 60 - 30) + "px";
        heart.style.top = e.pageY + "px";
        container.appendChild(heart);
        setTimeout(() => heart.remove(), 1200);
      }, i * 100);
    }
  });
</script>