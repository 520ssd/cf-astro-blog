---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface LovePostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: LovePostRow[] = [];
let totalPosts = 0;

try {
  const db = getDb(env.DB);

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} LIKE 'love/%'`
    );
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} LIKE 'love/%'`
    )
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch {}

const totalPages = Math.ceil(totalPosts / limit);
const startDateStr = "2026-03-20";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

function getPreviewContent(content: string, maxLen = 80): string {
  const text = content.replace(/[#*`\[\]!>\-]/g, "").replace(/\s+/g, " ").trim();
  return text.length > maxLen ? text.slice(0, maxLen) + "…" : text;
}

const regretLevels = ["😤 轻度", "😠 中度", "💢 重度", "🔥 严重", "💔 非常严重"];
function getRandomRegret(): string {
  return regretLevels[Math.floor(Math.random() * regretLevels.length)];
}
---

<Base title="情侣犯错记录" description="犯错要留证据，反省必须到位 ❤️">
  <div class="love-page">
    <!-- 顶部浪漫头部 -->
    <header class="love-hero">
      <div class="love-hero-glow"></div>
      <div class="love-hero-content">
        <div class="love-icon-row">
          <span class="love-emoji">📝</span>
          <span class="love-heart-pulse">💗</span>
          <span class="love-emoji">🔍</span>
        </div>
        <h1 class="love-title">情侣犯错记录本</h1>
        <p class="love-subtitle">每一次犯错，都是更懂你的机会</p>
        <div class="love-stats">
          <div class="love-stat-card">
            <div class="love-stat-icon">💑</div>
            <div class="love-stat-value">{loveDays}</div>
            <div class="love-stat-label">相恋天数</div>
          </div>
          <div class="love-stat-divider"></div>
          <div class="love-stat-card">
            <div class="love-stat-icon">📋</div>
            <div class="love-stat-value">{totalPosts}</div>
            <div class="love-stat-label">犯错记录</div>
          </div>
          <div class="love-stat-divider"></div>
          <div class="love-stat-card">
            <div class="love-stat-icon">💪</div>
            <div class="love-stat-value">{totalPosts > 0 ? Math.max(loveDays - totalPosts, 0) : loveDays}</div>
            <div class="love-stat-label">无错天数</div>
          </div>
        </div>
      </div>
    </header>

    <!-- 记录列表 -->
    <main class="love-main">
      {posts.length > 0 ? (
        <div class="love-timeline">
          {posts.map((post, i) => {
            const previewContent = getPreviewContent(post.content);
            const regretLevel = getRandomRegret();
            const dateObj = new Date(post.publishedAt!);
            const dateStr = `${dateObj.getFullYear()}年${dateObj.getMonth() + 1}月${dateObj.getDate()}日`;
            const timeStr = `${String(dateObj.getHours()).padStart(2, "0")}:${String(dateObj.getMinutes()).padStart(2, "0")}`;
            const isLeft = i % 2 === 0;

            return (
              <div class={`love-timeline-item ${isLeft ? "is-left" : "is-right"}`}>
                <div class="love-timeline-dot">
                  <span>💔</span>
                </div>
                <div class="love-timeline-card">
                  <a href={`/${post.slug}`} class="love-card-link">
                    {post.featuredImageKey && (
                      <div class="love-card-image-wrap">
                        <img
                          src={`/media/${post.featuredImageKey}`}
                          alt={post.title}
                          class="love-card-image"
                          loading="lazy"
                        />
                        <div class="love-card-image-overlay"></div>
                      </div>
                    )}
                    <div class="love-card-content">
                      <div class="love-card-header">
                        <span class="love-card-number">#{String(i + 1).padStart(2, "0")}</span>
                        <span class="love-card-regret">{regretLevel}</span>
                      </div>
                      <h3 class="love-card-title">{post.title}</h3>
                      <p class="love-card-excerpt">{post.excerpt || previewContent}</p>
                      <div class="love-card-footer">
                        <time class="love-card-date">
                          <span class="love-card-date-icon">📅</span>
                          {dateStr}
                        </time>
                        <span class="love-card-time">{timeStr}</span>
                      </div>
                    </div>
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="love-empty">
          <div class="love-empty-icon">🎉</div>
          <h2 class="love-empty-title">太棒了！还没有犯错记录</h2>
          <p class="love-empty-desc">
            继续保持哦～每一次包容和理解，都让我们的爱更坚定
          </p>
          <div class="love-empty-hearts">
            <span>❤️</span><span>💕</span><span>💗</span><span>💖</span><span>❤️</span>
          </div>
        </div>
      )}

      <!-- 分页 -->
      {totalPages > 1 && (
        <div class="love-pagination">
          {page > 1 && (
            <a href={`/love?page=${page - 1}`} class="love-page-btn">
              ← 上一页
            </a>
          )}
          <span class="love-page-info">
            {page} / {totalPages}
          </span>
          {page < totalPages && (
            <a href={`/love?page=${page + 1}`} class="love-page-btn">
              下一页 →
            </a>
          )}
        </div>
      )}
    </main>

    <!-- 底部寄语 -->
    <footer class="love-footer">
      <p>💌 每一次记录，都是为了让我们的爱变得更好</p>
      <p class="love-footer-sub">JY先生 ❤️ JX女士</p>
    </footer>
  </div>

  <div id="heartContainer"></div>
</Base>

<style is:global>
  :root {
    --love-pink: #ff6b9d;
    --love-pink-light: #ffb6ce;
    --love-pink-dark: #e8557d;
    --love-bg: #0d0d1a;
    --love-card-bg: rgba(255, 240, 245, 0.03);
    --love-card-border: rgba(255, 180, 200, 0.08);
    --love-text: #e8e8f0;
    --love-text-muted: #999;
    --love-glow: rgba(255, 107, 157, 0.15);
  }

  .love-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #0d0d1a 0%, #1a1025 40%, #0d0d1a 100%);
    color: var(--love-text);
    overflow-x: hidden;
  }

  /* ===== 顶部区域 ===== */
  .love-hero {
    position: relative;
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    overflow: hidden;
  }

  .love-hero-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 107, 157, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .love-hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .love-icon-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .love-emoji {
    font-size: 1.8rem;
    animation: loveFloat 3s ease-in-out infinite;
  }

  .love-emoji:nth-child(1) { animation-delay: 0s; }
  .love-emoji:nth-child(3) { animation-delay: 1.5s; }

  .love-heart-pulse {
    font-size: 2.2rem;
    animation: loveHeartPulse 1.5s ease-in-out infinite;
  }

  @keyframes loveFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes loveHeartPulse {
    0%, 100% { transform: scale(1); }
    15% { transform: scale(1.25); }
    30% { transform: scale(1); }
  }

  .love-title {
    font-size: 2.4rem;
    font-weight: 800;
    background: linear-gradient(135deg, #ff6b9d 0%, #ffb6ce 50%, #ff6b9d 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: loveGradient 3s ease-in-out infinite;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  @keyframes loveGradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .love-subtitle {
    font-size: 1.05rem;
    color: var(--love-text-muted);
    margin: 0 0 2rem;
    letter-spacing: 0.05em;
  }

  /* ===== 统计卡片 ===== */
  .love-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .love-stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    min-width: 90px;
  }

  .love-stat-icon {
    font-size: 1.5rem;
  }

  .love-stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--love-pink);
    font-variant-numeric: tabular-nums;
  }

  .love-stat-label {
    font-size: 0.8rem;
    color: var(--love-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .love-stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.08);
  }

  /* ===== 时间线列表 ===== */
  .love-main {
    max-width: 800px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }

  .love-timeline {
    position: relative;
    padding: 2rem 0;
  }

  .love-timeline::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 107, 157, 0.3) 10%,
      rgba(255, 107, 157, 0.3) 90%,
      transparent 100%
    );
    transform: translateX(-50%);
  }

  .love-timeline-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    margin-bottom: 2.5rem;
    width: 100%;
  }

  .love-timeline-item.is-left {
    flex-direction: row;
    padding-right: calc(50% + 2rem);
  }

  .love-timeline-item.is-right {
    flex-direction: row-reverse;
    padding-left: calc(50% + 2rem);
  }

  .love-timeline-dot {
    position: absolute;
    left: 50%;
    top: 1.5rem;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    background: var(--love-bg);
    border: 2px solid rgba(255, 107, 157, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    font-size: 1rem;
    box-shadow: 0 0 15px rgba(255, 107, 157, 0.15);
  }

  .love-timeline-card {
    flex: 1;
    transition: transform 0.3s ease;
  }

  .love-timeline-card:hover {
    transform: translateY(-4px);
  }

  .love-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--love-card-bg);
    border: 1px solid var(--love-card-border);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .love-card-link:hover {
    border-color: rgba(255, 107, 157, 0.3);
    box-shadow: 0 12px 40px rgba(255, 107, 157, 0.08);
  }

  .love-card-image-wrap {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .love-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .love-card-link:hover .love-card-image {
    transform: scale(1.05);
  }

  .love-card-image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(transparent, var(--love-card-bg));
  }

  .love-card-content {
    padding: 1.2rem 1.4rem 1.4rem;
  }

  .love-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.6rem;
  }

  .love-card-number {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--love-pink);
    background: rgba(255, 107, 157, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    letter-spacing: 0.05em;
  }

  .love-card-regret {
    font-size: 0.75rem;
    color: #ff9b6b;
    background: rgba(255, 155, 107, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }

  .love-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    color: #f0e0e8;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .love-card-excerpt {
    font-size: 0.88rem;
    color: var(--love-text-muted);
    margin: 0 0 0.8rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .love-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .love-card-date {
    font-size: 0.8rem;
    color: #bbb;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .love-card-date-icon {
    font-size: 0.9rem;
  }

  .love-card-time {
    font-size: 0.78rem;
    color: var(--love-pink);
    font-weight: 500;
  }

  /* ===== 空状态 ===== */
  .love-empty {
    text-align: center;
    padding: 4rem 1rem;
    animation: loveFadeIn 0.6s ease;
  }

  @keyframes loveFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .love-empty-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: loveFloat 2s ease-in-out infinite;
  }

  .love-empty-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f0e0e8;
    margin: 0 0 0.5rem;
  }

  .love-empty-desc {
    color: var(--love-text-muted);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .love-empty-hearts {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    font-size: 1.5rem;
    animation: loveFloat 3s ease-in-out infinite;
  }

  /* ===== 分页 ===== */
  .love-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem 0;
  }

  .love-page-btn {
    padding: 0.6rem 1.2rem;
    border: 1px solid rgba(255, 107, 157, 0.2);
    border-radius: 8px;
    color: var(--love-pink);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .love-page-btn:hover {
    background: rgba(255, 107, 157, 0.1);
    border-color: var(--love-pink);
  }

  .love-page-info {
    font-size: 0.9rem;
    color: var(--love-text-muted);
  }

  /* ===== 底部 ===== */
  .love-footer {
    text-align: center;
    padding: 2rem 1rem 3rem;
    color: var(--love-text-muted);
  }

  .love-footer p {
    margin: 0 0 0.3rem;
    font-size: 0.9rem;
  }

  .love-footer-sub {
    font-size: 0.85rem !important;
    color: var(--love-pink);
    font-weight: 500;
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .love-timeline::before {
      left: 20px;
    }

    .love-timeline-item.is-left,
    .love-timeline-item.is-right {
      flex-direction: row;
      padding-left: 3rem;
      padding-right: 0;
    }

    .love-timeline-dot {
      left: 20px;
      width: 32px;
      height: 32px;
      font-size: 0.8rem;
    }

    .love-title {
      font-size: 1.8rem;
    }

    .love-stats {
      gap: 1rem;
    }

    .love-stat-value {
      font-size: 1.4rem;
    }

    .love-stat-divider {
      height: 30px;
    }
  }

  /* ===== 爱心特效 ===== */
  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ff87a5;
    font-size: 18px;
    animation: fall 5s linear infinite;
    opacity: 0.6;
    pointer-events: none;
    z-index: 999;
  }

  .click-float-heart {
    position: absolute;
    color: #ff5e8c;
    font-size: 28px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }

  @keyframes fall {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.7;
    }
    100% {
      transform: translateY(100vh) rotate(360deg);
      opacity: 0;
    }
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 1;
    }
    100% {
      transform: translateY(-180px) scale(1.2);
      opacity: 0;
    }
  }
</style>

<script>
  const container = document.getElementById("heartContainer");

  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = ["❤️", "💕", "💗", "💖", "🩷"][Math.floor(Math.random() * 5)];
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = Math.random() * 3 + 3 + "s";
    heart.style.fontSize = Math.random() * 12 + 14 + "px";
    container?.appendChild(heart);
    setTimeout(() => heart.remove(), 7000);
  }

  setInterval(createFallHeart, 400);

  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "❤️";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    container?.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  document.body.addEventListener("dblclick", (e) => {
    const emojis = ["💗", "💖", "💕", "💝", "🩷", "❤️‍🔥"];
    for (let i = 0; i < 8; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
        heart.style.fontSize = Math.random() * 24 + 28 + "px";
        heart.style.left = e.pageX + (Math.random() * 80 - 40) + "px";
        heart.style.top = e.pageY + "px";
        container?.appendChild(heart);
        setTimeout(() => heart.remove(), 1400);
      }, i * 80);
    }
  });
</script>