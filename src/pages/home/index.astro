---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const articleSlug = Astro.url.searchParams.get("article");
const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface HomePostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: HomePostRow[] = [];
let totalPosts = 0;
let detailPost: HomePostRow | null = null;

try {
  const db = getDb(env.DB);

  if (articleSlug) {
    const [found] = await db
      .select({
        title: blogPosts.title,
        slug: blogPosts.slug,
        excerpt: blogPosts.excerpt,
        publishedAt: blogPosts.publishedAt,
        featuredImageKey: blogPosts.featuredImageKey,
        content: blogPosts.content,
      })
      .from(blogPosts)
      .where(
        sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} = ${articleSlug}`
      )
      .limit(1);
    detailPost = found || null;
  }

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'home' OR ${blogPosts.slug} LIKE 'home/%' OR ${blogPosts.slug} LIKE 'home-%')`
    );
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND (${blogPosts.slug} = 'home' OR ${blogPosts.slug} LIKE 'home/%' OR ${blogPosts.slug} LIKE 'home-%')`
    )
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch (e) {
  console.error("Home page data fetch error:", e);
}

const totalPages = Math.ceil(totalPosts / limit);
const startDateStr = "2026-03-21";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

function getPreviewContent(content: string, maxLen = 100): string {
  const text = content.replace(/[#*`\[\]!>\-]/g, "").replace(/\s+/g, " ").trim();
  return text.length > maxLen ? text.slice(0, maxLen) + "…" : text;
}

const moodEmojiMap: Record<string, string> = {
  "开心": "🥰",
  "幸福": "💕",
  "感动": "🥹",
  "甜蜜": "🍯",
  "想念": "💭",
  "约会": "🌹",
  "惊喜": "🎁",
  "日常": "☀️",
};

function getMoodDisplay(excerpt: string | null): string {
  if (!excerpt || !excerpt.trim()) return "☀️ 日常";
  const mood = excerpt.trim();
  const emoji = moodEmojiMap[mood] || "💖";
  return `${emoji} ${mood}`;
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const day = date.getDate();
  return `${year}.${String(month).padStart(2, "0")}.${String(day).padStart(2, "0")}`;
}

function formatDetailDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日 ${String(date.getHours()).padStart(2, "0")}:${String(date.getMinutes()).padStart(2, "0")}`;
}

const loveQuotes = [
  "你是我一生只会遇见一次的惊喜",
  "有你的每一天，都是情人节",
  "世间万物，不及你眉眼半分",
  "想和你一起，看遍世间所有浪漫",
  "遇见你之后，我的世界有了光",
  "你是我的今天，也是我的明天",
  "爱不是相互凝望，而是一起朝同一个方向看",
  "我在人间贩卖黄昏，只为收集世间温柔去见你",
];
const todayQuote = loveQuotes[Math.floor(Math.random() * loveQuotes.length)];
---

<Base title="我们的恋爱日常" description="记录和你在一起的每一天 💕">
  <div class="home-page">
    {detailPost ? (
      <!-- ===== 文章详情页 ===== -->
      <article class="detail-page">
        <header class="detail-hero">
          <div class="detail-hero-badge">
            <span>📖 恋爱日常</span>
          </div>
          <h1 class="detail-title">{detailPost.title}</h1>
          <div class="detail-meta">
            <span>💑 相恋第 {loveDays} 天</span>
            {detailPost.publishedAt && <span>📅 {formatDetailDate(detailPost.publishedAt)}</span>}
          </div>
        </header>

        {detailPost.featuredImageKey && (
          <div class="detail-image-wrap">
            <img src={`/media/${detailPost.featuredImageKey}`} alt={detailPost.title} class="detail-image" />
          </div>
        )}

        <div class="detail-body">
          <div class="detail-content" set:html={detailPost.content}></div>
        </div>

        <footer class="detail-footer">
          <a href="/home" class="detail-back-btn">← 返回恋爱日常</a>
          <div class="detail-footer-hearts">❤️ 💕 💗 💖</div>
        </footer>
      </article>
    ) : (
      <!-- ===== 列表页 ===== -->
      <>
        <!-- 头部 -->
        <header class="hero" id="heroSection">
          <div class="hero-decor">
            <span class="hero-decor-flower">🌸</span>
            <span class="hero-decor-heart" id="heroCenterHeart">💗</span>
            <span class="hero-decor-flower">🌸</span>
          </div>
          <div class="hero-date-badge">
            <span class="hero-date-day" id="liveDay">{new Date().getDate()}</span>
            <span class="hero-date-month">{new Date().getMonth() + 1} 月</span>
          </div>
          <h1 class="hero-title">
            <span class="hero-title-sub">Our Love Story</span>
            <span class="hero-title-main">恋爱日常</span>
          </h1>
          <p class="hero-quote" id="heroQuote">"{todayQuote}"</p>
          <div class="hero-stats">
            <div class="hero-stat">
              <div class="hero-stat-num" id="loveDaysCount">{loveDays}</div>
              <div class="hero-stat-label">相恋天数</div>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <div class="hero-stat-num">{totalPosts}</div>
              <div class="hero-stat-label">甜蜜瞬间</div>
            </div>
          </div>

          <!-- 拍立得照片墙 -->
          <div class="hero-polaroid-wall" id="polaroidWall">
            <div class="polaroid polaroid-1" data-polaroid>
              <div class="polaroid-inner">
                <div class="polaroid-img">💑</div>
                <div class="polaroid-text">第一天</div>
              </div>
            </div>
            <div class="polaroid polaroid-2" data-polaroid>
              <div class="polaroid-inner">
                <div class="polaroid-img">💕</div>
                <div class="polaroid-text">第一次约会</div>
              </div>
            </div>
            <div class="polaroid polaroid-3" data-polaroid>
              <div class="polaroid-inner">
                <div class="polaroid-img">💗</div>
                <div class="polaroid-text">永远爱你</div>
              </div>
            </div>
          </div>

          <div class="hero-scroll-hint">
            <span>下滑看我们的故事</span>
            <span class="hero-scroll-arrow">↓</span>
          </div>
        </header>

        <!-- 互动留言板 -->
        <div class="love-note-wall" id="loveNoteWall">
          <div class="love-note-wall-inner">
            <h3 class="love-note-title">💌 留下你的悄悄话</h3>
            <div class="love-note-input-row">
              <input type="text" id="loveNoteInput" class="love-note-input" placeholder="写一句想对TA说的话..." maxlength="80" />
              <button id="loveNoteSend" class="love-note-send">发送 💕</button>
            </div>
            <div class="love-note-list" id="loveNoteList">
              <div class="love-note-item">
                <span class="love-note-avatar">👦</span>
                <span class="love-note-text">我会一直陪着你</span>
                <span class="love-note-heart">❤️</span>
              </div>
              <div class="love-note-item">
                <span class="love-note-avatar">👧</span>
                <span class="love-note-text">你是我的小太阳</span>
                <span class="love-note-heart">☀️</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 日记列表 -->
        <main class="main">
          <div class="section-head">
            <h2 class="section-title">📖 我们的故事</h2>
            <p class="section-desc">每一个瞬间，都值得被珍藏</p>
          </div>

          {posts.length > 0 ? (
            <div class="diary-grid">
              {posts.map((post, i) => {
                const previewContent = getPreviewContent(post.content);
                const moodDisplay = getMoodDisplay(post.excerpt);
                const dateStr = formatDate(post.publishedAt);

                return (
                  <article class="diary-card" data-card>
                    <a href={`/home?article=${post.slug}`} class="diary-card-link">
                      {post.featuredImageKey ? (
                        <div class="diary-card-image">
                          <img src={`/media/${post.featuredImageKey}`} alt={post.title} loading="lazy" />
                          <div class="diary-card-mood-tag">{moodDisplay}</div>
                          <div class="diary-card-image-heart">💗</div>
                        </div>
                      ) : (
                        <div class="diary-card-image diary-card-image-placeholder">
                          <span class="diary-card-placeholder-emoji">💌</span>
                          <div class="diary-card-mood-tag">{moodDisplay}</div>
                          <div class="diary-card-image-heart">💗</div>
                        </div>
                      )}
                      <div class="diary-card-body">
                        <div class="diary-card-meta">
                          <span class="diary-card-date">📅 {dateStr}</span>
                          <span class="diary-card-num">#{totalPosts - i}</span>
                        </div>
                        <h3 class="diary-card-title">{post.title}</h3>
                        <p class="diary-card-excerpt">{previewContent}</p>
                        <span class="diary-card-readmore">阅读更多 →</span>
                      </div>
                    </a>
                  </article>
                );
              })}
            </div>
          ) : (
            <div class="empty">
              <span class="empty-icon">💌</span>
              <h3>还没有恋爱日记</h3>
              <p>快来记录你们的甜蜜日常吧~</p>
            </div>
          )}

          {totalPages > 1 && (
            <div class="pagination">
              {page > 1 && <a href={`/home?page=${page - 1}`} class="page-btn">← 上一页</a>}
              <span class="page-info">{page} / {totalPages}</span>
              {page < totalPages && <a href={`/home?page=${page + 1}`} class="page-btn">下一页 →</a>}
            </div>
          )}
        </main>

        <!-- 底部 -->
        <footer class="footer">
          <div class="footer-hearts">❤️ 💕 💗 💖 💝</div>
          <p class="footer-text">JY先生 ❤️ JX女士</p>
          <p class="footer-sub">从 2026年3月21日 开始，一直爱下去</p>
        </footer>
      </>
    )}
  </div>

  <div id="heartContainer"></div>
</Base>

<style is:global>
  :root {
    --pink-50: #fff5f7;
    --pink-100: #ffe4ea;
    --pink-200: #ffb6ce;
    --pink-300: #ff87b5;
    --pink-400: #ff6b9d;
    --pink-500: #f05585;
    --text-dark: #4a3040;
    --text-mid: #7a6070;
    --text-light: #b090a0;
    --white: #ffffff;
    --shadow-sm: 0 2px 12px rgba(255, 107, 157, 0.06);
    --shadow-md: 0 8px 32px rgba(255, 107, 157, 0.1);
    --shadow-lg: 0 16px 48px rgba(255, 107, 157, 0.12);
  }

  .home-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #fff5f7 0%, #ffffff 20%, #fff8fa 50%, #ffffff 100%);
    color: var(--text-dark);
    overflow-x: hidden;
    font-family: "Georgia", "Noto Serif SC", serif;
  }

  /* ===== 头部 ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    background:
      radial-gradient(circle at 20% 30%, rgba(255, 182, 206, 0.12) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255, 107, 157, 0.06) 0%, transparent 50%);
    cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24'><text y='20' font-size='20'>💕</text></svg>") 12 12, auto;
  }

  .hero-decor {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
    animation: heroDecorFloat 3s ease-in-out infinite;
  }

  .hero-decor-flower {
    animation: heroFlowerSpin 4s ease-in-out infinite;
  }

  .hero-decor-heart {
    animation: heroHeartBeat 1.2s ease-in-out infinite;
    cursor: pointer;
    user-select: none;
  }

  @keyframes heroDecorFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes heroFlowerSpin {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(10deg); }
    75% { transform: rotate(-10deg); }
  }

  @keyframes heroHeartBeat {
    0%, 100% { transform: scale(1); }
    14% { transform: scale(1.25); }
    28% { transform: scale(1); }
    42% { transform: scale(1.25); }
    56% { transform: scale(1); }
  }

  .hero-date-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    padding: 0.5rem 1.2rem;
    background: rgba(255, 107, 157, 0.06);
    border: 1px solid rgba(255, 107, 157, 0.12);
    border-radius: 999px;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .hero-date-badge:hover {
    background: rgba(255, 107, 157, 0.1);
    transform: scale(1.04);
  }

  .hero-date-day {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--pink-400);
    line-height: 1;
  }

  .hero-date-month {
    font-size: 0.9rem;
    color: var(--text-mid);
    font-weight: 500;
  }

  .hero-title {
    margin: 0 0 1rem;
  }

  .hero-title-sub {
    display: block;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    color: var(--text-light);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
    font-family: system-ui, sans-serif;
  }

  .hero-title-main {
    display: block;
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ff6b9d 0%, #e8557d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.04em;
  }

  .hero-quote {
    font-size: 1rem;
    color: var(--text-light);
    font-style: italic;
    margin: 1.2rem 0 2rem;
    max-width: 400px;
    line-height: 1.7;
    cursor: pointer;
    transition: all 0.3s ease;
    user-select: none;
  }

  .hero-quote:hover {
    color: var(--pink-400);
    transform: scale(1.03);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .hero-stat {
    text-align: center;
  }

  .hero-stat-num {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--pink-400);
    font-variant-numeric: tabular-nums;
    transition: all 0.3s ease;
  }

  .hero-stat-label {
    font-size: 0.8rem;
    color: var(--text-light);
    letter-spacing: 0.06em;
    margin-top: 0.2rem;
  }

  .hero-stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 107, 157, 0.12);
  }

  /* ===== 拍立得照片墙 ===== */
  .hero-polaroid-wall {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .polaroid {
    background: var(--white);
    padding: 0.5rem 0.5rem 1rem;
    border-radius: 4px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
    transform: rotate(-3deg);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    animation: polaroidFloat 4s ease-in-out infinite;
  }

  .polaroid:nth-child(2) {
    transform: rotate(2deg);
    animation-delay: 0.5s;
    margin-top: 0.5rem;
  }

  .polaroid:nth-child(3) {
    transform: rotate(-1deg);
    animation-delay: 1s;
  }

  @keyframes polaroidFloat {
    0%, 100% { transform: rotate(-3deg) translateY(0); }
    50% { transform: rotate(-3deg) translateY(-8px); }
  }

  .polaroid:nth-child(2) {
    animation-name: polaroidFloat2;
  }

  @keyframes polaroidFloat2 {
    0%, 100% { transform: rotate(2deg) translateY(0); }
    50% { transform: rotate(2deg) translateY(-8px); }
  }

  .polaroid:nth-child(3) {
    animation-name: polaroidFloat3;
  }

  @keyframes polaroidFloat3 {
    0%, 100% { transform: rotate(-1deg) translateY(0); }
    50% { transform: rotate(-1deg) translateY(-8px); }
  }

  .polaroid:hover {
    transform: rotate(0deg) scale(1.12) !important;
    box-shadow: 0 12px 32px rgba(255, 107, 157, 0.15);
    z-index: 10;
    animation-play-state: paused;
  }

  .polaroid-inner {
    width: 90px;
    height: 100px;
    background: linear-gradient(135deg, #fff0f3, #ffe4ea);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
  }

  .polaroid-img {
    font-size: 2.2rem;
  }

  .polaroid-text {
    font-size: 0.65rem;
    color: var(--text-mid);
    letter-spacing: 0.04em;
  }

  /* ===== 悄悄话留言板 ===== */
  .love-note-wall {
    max-width: 700px;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }

  .love-note-wall-inner {
    background: var(--white);
    border-radius: 20px;
    padding: 1.8rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(255, 182, 206, 0.15);
  }

  .love-note-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--pink-500);
    margin: 0 0 1rem;
    text-align: center;
  }

  .love-note-input-row {
    display: flex;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .love-note-input {
    flex: 1;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 182, 206, 0.3);
    border-radius: 999px;
    font-size: 0.9rem;
    outline: none;
    transition: all 0.3s ease;
    font-family: inherit;
    color: var(--text-dark);
  }

  .love-note-input:focus {
    border-color: var(--pink-400);
    box-shadow: 0 0 0 3px rgba(255, 107, 157, 0.06);
  }

  .love-note-input::placeholder {
    color: var(--text-light);
  }

  .love-note-send {
    padding: 0.7rem 1.4rem;
    background: linear-gradient(135deg, #ff6b9d, #f05585);
    color: white;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .love-note-send:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.25);
  }

  .love-note-send:active {
    transform: scale(0.96);
  }

  .love-note-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 200px;
    overflow-y: auto;
  }

  .love-note-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    background: rgba(255, 107, 157, 0.03);
    border-radius: 10px;
    animation: noteSlideIn 0.4s ease;
  }

  @keyframes noteSlideIn {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .love-note-avatar {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .love-note-text {
    flex: 1;
    font-size: 0.88rem;
    color: var(--text-mid);
  }

  .love-note-heart {
    font-size: 0.9rem;
    animation: heroHeartBeat 2s ease-in-out infinite;
    cursor: pointer;
    user-select: none;
  }

  /* ===== 日记网格 ===== */
  .main {
    max-width: 1000px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 0.4rem;
  }

  .section-desc {
    color: var(--text-light);
    font-size: 0.9rem;
    margin: 0;
  }

  .diary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .diary-card {
    background: var(--white);
    border-radius: 20px;
    overflow: hidden;
