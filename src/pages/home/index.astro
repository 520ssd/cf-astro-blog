    font-size: 0.85rem;
    color: #888;
    margin: 0;
  }

  /* ===== 爱心特效 ===== */
  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ff87a5;
    font-size: 18px;
    animation: fall 6s linear infinite;
    opacity: 0.5;
    pointer-events: none;
    z-index: 999;
  }

  .click-float-heart {
    position: absolute;
    color: #ff5e8c;
    font-size: 28px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }

  @keyframes fall {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.7;
    }
    100% {
      transform: translateY(100vh) rotate(360deg);
      opacity: 0;
    }
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.8);
      opacity: 1;
    }
    100% {
      transform: translateY(-180px) scale(1.2);
      opacity: 0;
    }
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .home-hero-title {
      font-size: 2rem;
    }
    .love-gradient-text {
      font-size: 2.4rem;
    }
    .home-hero-title-line:first-child {
      font-size: 1.4rem;
    }
    .home-hero-day {
      font-size: 2.2rem;
    }
    .home-hero-stat-number {
      font-size: 1.5rem;
    }

    .home-diary-card-inner {
      flex-direction: column !important;
    }
    .home-diary-card-image {
      flex: 0 0 200px;
      width: 100%;
    }
    .home-diary-card-image-overlay {
      background: linear-gradient(to bottom, rgba(10, 10, 26, 0) 0%, rgba(10, 10, 26, 0.5) 100%) !important;
    }
    .home-diary-card-body {
      padding: 1.2rem;
    }
  }
</style>

<script>
  // 星星生成
  const starsContainer = document.getElementById("heroStars");
  if (starsContainer) {
    for (let i = 0; i < 50; i++) {
      const star = document.createElement("div");
      star.className = "hero-star";
      star.style.left = Math.random() * 100 + "%";
      star.style.top = Math.random() * 100 + "%";
      star.style.width = Math.random() * 3 + 1 + "px";
      star.style.height = star.style.width;
      star.style.animationDelay = Math.random() * 3 + "s";
      star.style.animationDuration = Math.random() * 3 + 2 + "s";
      starsContainer.appendChild(star);
    }
  }

  // 爱心飘落特效
  const heartContainer = document.getElementById("heartContainer");

  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = ["❤️", "💕", "💗", "💖", "🩷", "💝", "🌸", "✨"][Math.floor(Math.random() * 8)];
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = Math.random() * 4 + 4 + "s";
    heart.style.fontSize = Math.random() * 14 + 12 + "px";
    heartContainer?.appendChild(heart);
    setTimeout(() => heart.remove(), 8000);
  }

  setInterval(createFallHeart, 500);
  for (let i = 0; i < 8; i++) {
    setTimeout(createFallHeart, i * 300);
  }

  // 点击爱心
  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "💕";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    heartContainer?.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  // 双击爱心爆炸
  document.body.addEventListener("dblclick", (e) => {
    const emojis = ["💗", "💖", "💕", "💝", "🩷", "🌸", "✨", "💘"];
    for (let i = 0; i < 12; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
        heart.style.fontSize = Math.random() * 28 + 24 + "px";
        heart.style.left = e.pageX + (Math.random() * 100 - 50) + "px";
        heart.style.top = e.pageY + "px";
        heartContainer?.appendChild(heart);
        setTimeout(() => heart.remove(), 1500);
      }, i * 60);
    }
  });
</script>