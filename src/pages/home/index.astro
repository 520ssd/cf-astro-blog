    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  .home-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .home-section-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
