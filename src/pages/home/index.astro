    margin: 0;
  }

  /* ===== 爱心特效 ===== */
  .fall-heart {
    position: fixed;
    top: -10%;
    color: #ffb6ce;
    font-size: 16px;
    animation: fall 7s linear infinite;
    opacity: 0.5;
    pointer-events: none;
    z-index: 999;
  }

  .click-float-heart {
    position: absolute;
    color: #ff6b9d;
    font-size: 26px;
    pointer-events: none;
    animation: floatUp 1s ease-out forwards;
    z-index: 999;
  }

  .heart-particle {
    position: absolute;
    pointer-events: none;
    z-index: 998;
    animation: heartParticle 0.8s ease-out forwards;
  }

  @keyframes fall {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
    100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
  }

  @keyframes floatUp {
    0% { transform: translateY(0) scale(0.8); opacity: 1; }
    100% { transform: translateY(-160px) scale(1.2); opacity: 0; }
  }

  @keyframes heartParticle {
    0% { transform: translate(0, 0) scale(1); opacity: 1; }
    100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
  }

  @media (max-width: 768px) {
    .hero-title-main { font-size: 2.2rem; }
    .hero-stat-num { font-size: 1.6rem; }
    .diary-grid { grid-template-columns: 1fr; }
    .detail-title { font-size: 1.5rem; }
    .polaroid-inner { width: 70px; height: 80px; }
    .polaroid-img { font-size: 1.6rem; }
    .love-note-input-row { flex-direction: column; }
  }
</style>

<script>
  // ===== 爱心容器 =====
  const heartContainer = document.getElementById("heartContainer");

  // ===== 爱心飘落 =====
  function createFallHeart() {
    const heart = document.createElement("div");
    heart.className = "fall-heart";
    heart.innerHTML = ["❤️", "💕", "💗", "💖", "🩷", "🌸", "✨", "💝"][Math.floor(Math.random() * 8)];
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = Math.random() * 5 + 5 + "s";
    heart.style.fontSize = Math.random() * 12 + 12 + "px";
    heartContainer?.appendChild(heart);
    setTimeout(() => heart.remove(), 9000);
  }
  setInterval(createFallHeart, 600);
  for (let i = 0; i < 6; i++) setTimeout(createFallHeart, i * 400);

  // ===== 点击爱心 =====
  document.body.addEventListener("click", (e) => {
    const heart = document.createElement("div");
    heart.className = "click-float-heart";
    heart.innerHTML = "💕";
    heart.style.left = e.pageX + "px";
    heart.style.top = e.pageY + "px";
    heartContainer?.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
  });

  // ===== 双击爱心爆炸 =====
  document.body.addEventListener("dblclick", (e) => {
    const emojis = ["💗", "💖", "💕", "💝", "🩷", "🌸", "✨", "💘"];
    for (let i = 0; i < 12; i++) {
      setTimeout(() => {
        const heart = document.createElement("div");
        heart.className = "click-float-heart";
        heart.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
        heart.style.fontSize = Math.random() * 24 + 22 + "px";
        heart.style.left = e.pageX + (Math.random() * 90 - 45) + "px";
        heart.style.top = e.pageY + "px";
        heartContainer?.appendChild(heart);
        setTimeout(() => heart.remove(), 1400);
      }, i * 60);
    }
  });

  // ===== 鼠标移动粒子轨迹 =====
  let lastParticleTime = 0;
  document.body.addEventListener("mousemove", (e) => {
    const now = Date.now();
    if (now - lastParticleTime < 80) return;
    lastParticleTime = now;

    const particle = document.createElement("div");
    particle.className = "heart-particle";
    particle.innerHTML = ["💕", "✨", "💗", "🌸", "🩷"][Math.floor(Math.random() * 5)];
    particle.style.left = e.pageX + "px";
    particle.style.top = e.pageY + "px";
    particle.style.fontSize = Math.random() * 10 + 10 + "px";
    particle.style.setProperty("--dx", (Math.random() * 60 - 30) + "px");
    particle.style.setProperty("--dy", (Math.random() * -60 - 20) + "px");
    heartContainer?.appendChild(particle);
    setTimeout(() => particle.remove(), 800);
  });

  // ===== 中心爱心点击变色 =====
  const centerHeart = document.getElementById("heroCenterHeart");
  if (centerHeart) {
    const heartColors = ["💗", "💖", "💝", "💘", "❤️‍🔥", "🩷", "💕"];
    let colorIndex = 0;
    centerHeart.addEventListener("click", (e) => {
      e.stopPropagation();
      colorIndex = (colorIndex + 1) % heartColors.length;
      centerHeart.innerHTML = heartColors[colorIndex];
      // 点击时放大动画
      centerHeart.style.transform = "scale(1.5)";
      setTimeout(() => { centerHeart.style.transform = "scale(1)"; }, 200);

      // 周围冒出爱心
      for (let i = 0; i < 8; i++) {
        const spark = document.createElement("div");
        spark.className = "heart-particle";
        spark.innerHTML = ["💕", "✨", "💗"][Math.floor(Math.random() * 3)];
        spark.style.left = (centerHeart.getBoundingClientRect().left + centerHeart.offsetWidth / 2) + "px";
        spark.style.top = (centerHeart.getBoundingClientRect().top + centerHeart.offsetHeight / 2) + "px";
        spark.style.fontSize = "18px";
        spark.style.setProperty("--dx", (Math.random() * 100 - 50) + "px");
        spark.style.setProperty("--dy", (Math.random() * -100 - 20) + "px");
        heartContainer?.appendChild(spark);
        setTimeout(() => spark.remove(), 900);
      }
    });
  }

  // ===== 格言点击切换 =====
  const heroQuote = document.getElementById("heroQuote");
  if (heroQuote) {
    const quotes = [
      "你是我一生只会遇见一次的惊喜",
      "有你的每一天，都是情人节",
      "世间万物，不及你眉眼半分",
      "想和你一起，看遍世间所有浪漫",
      "遇见你之后，我的世界有了光",
      "你是我的今天，也是我的明天",
      "爱不是相互凝望，而是一起朝同一个方向看",
      "我在人间贩卖黄昏，只为收集世间温柔去见你",
      "你一笑，我的世界就亮了",
      "和你在一起，连空气都是甜的",
    ];
    let quoteIdx = 0;
    heroQuote.addEventListener("click", (e) => {
      e.stopPropagation();
      quoteIdx = (quoteIdx + 1) % quotes.length;
      heroQuote.innerHTML = `"${quotes[quoteIdx]}"`;
      heroQuote.style.transform = "scale(1.08)";
      setTimeout(() => { heroQuote.style.transform = "scale(1)"; }, 200);
    });
  }

  // ===== 拍立得照片点击翻转 =====
  document.querySelectorAll("[data-polaroid]").forEach((p) => {
    const emojis = ["💑", "💕", "💗", "💖", "💝", "🌹", "🎁", "💘", "🥰", "✨"];
    p.addEventListener("click", (e) => {
      e.stopPropagation();
      const img = p.querySelector(".polaroid-img");
      if (img) {
        const current = img.innerHTML;
        let newEmoji = emojis[Math.floor(Math.random() * emojis.length)];
        while (newEmoji === current && emojis.length > 1) {
          newEmoji = emojis[Math.floor(Math.random() * emojis.length)];
        }
        img.innerHTML = newEmoji;
      }
      p.style.transform = "rotate(0deg) scale(1.2)";
      setTimeout(() => { p.style.transform = ""; }, 300);
    });
  });

  // ===== 悄悄话留言板 =====
  const noteInput = document.getElementById("loveNoteInput");
  const noteSend = document.getElementById("loveNoteSend");
  const noteList = document.getElementById("loveNoteList");

  function addLoveNote(text) {
    if (!text.trim() || !noteList) return;
    const avatars = ["👦", "👧", "🐻", "🐰", "🦊", "🐱", "🐶", "🌸"];
    const hearts = ["❤️", "💕", "💗", "💖", "💝", "🩷"];
    const item = document.createElement("div");
    item.className = "love-note-item";
    item.innerHTML = `
      <span class="love-note-avatar">${avatars[Math.floor(Math.random() * avatars.length)]}</span>
      <span class="love-note-text">${text.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</span>
      <span class="love-note-heart">${hearts[Math.floor(Math.random() * hearts.length)]}</span>
    `;
    noteList.insertBefore(item, noteList.firstChild);

    // 点击爱心变色
    const heartEl = item.querySelector(".love-note-heart");
    heartEl?.addEventListener("click", (e) => {
      e.stopPropagation();
      const newHeart = hearts[Math.floor(Math.random() * hearts.length)];
      heartEl.innerHTML = newHeart;
    });

    // 限制数量
    while (noteList.children.length > 20) {
      noteList.lastChild?.remove();
    }

    // 存 localStorage
    try {
      const notes = JSON.parse(localStorage.getItem("loveNotes") || "[]");
      notes.unshift(text);
      localStorage.setItem("loveNotes", JSON.stringify(notes.slice(0, 20)));
    } catch {}
  }

  noteSend?.addEventListener("click", () => {
    if (noteInput && noteInput.value.trim()) {
      addLoveNote(noteInput.value.trim());
      noteInput.value = "";
      noteInput.focus();
    }
  });

  noteInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      noteSend?.click();
    }
  });

  // 加载历史留言
  try {
    const saved = JSON.parse(localStorage.getItem("loveNotes") || "[]");
    saved.forEach((text) => addLoveNote(text));
  } catch {}

  // ===== 卡片长按爱心弹出 =====
  document.querySelectorAll("[data-card]").forEach((card) => {
    card.addEventListener("click", function(e) {
      const heart = this.querySelector(".diary-card-image-heart");
      if (heart) {
        heart.style.transform = "translate(-50%, -50%) scale(1)";
        heart.style.opacity = "1";
        setTimeout(() => {
          heart.style.transform = "translate(-50%, -50%) scale(0)";
          heart.style.opacity = "0";
        }, 500);
      }
    });
  });
</script>