---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, sql } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";

const page = Number(Astro.url.searchParams.get("page") || "1");
const limit = 12;
const offset = (page - 1) * limit;

interface HomePostRow {
  title: string;
  slug: string;
  excerpt: string | null;
  publishedAt: string | null;
  featuredImageKey: string | null;
  content: string;
}

let posts: HomePostRow[] = [];
let totalPosts = 0;

try {
  const db = getDb(env.DB);

  const [countRes] = await db
    .select({ count: sql<number>`count(*)` })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} LIKE 'home/%'`
    );
  totalPosts = countRes?.count ?? 0;

  posts = await db
    .select({
      title: blogPosts.title,
      slug: blogPosts.slug,
      excerpt: blogPosts.excerpt,
      publishedAt: blogPosts.publishedAt,
      featuredImageKey: blogPosts.featuredImageKey,
      content: blogPosts.content,
    })
    .from(blogPosts)
    .where(
      sql`${getPublicPostVisibilityCondition()} AND ${blogPosts.slug} LIKE 'home/%'`
    )
    .orderBy(desc(blogPosts.publishedAt))
    .limit(limit)
    .offset(offset);
} catch (e) {
  console.error("Home page data fetch error:", e);
}

const totalPages = Math.ceil(totalPosts / limit);
const startDateStr = "2026-03-21";

function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);

function getPreviewContent(content: string, maxLen = 100): string {
  const text = content.replace(/[#*`\[\]!>\-]/g, "").replace(/\s+/g, " ").trim();
  return text.length > maxLen ? text.slice(0, maxLen) + "…" : text;
}

const moodEmojiMap: Record<string, string> = {
  "开心": "🥰",
  "幸福": "💕",
  "感动": "🥹",
  "甜蜜": "🍯",
  "想念": "💭",
  "约会": "🌹",
  "惊喜": "🎁",
  "日常": "☀️",
};

function getMoodDisplay(excerpt: string | null): string {
  if (!excerpt || !excerpt.trim()) return "☀️ 日常";
  const mood = excerpt.trim();
  const emoji = moodEmojiMap[mood] || "💖";
  return `${emoji} ${mood}`;
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  if (Number.isNaN(date.getTime())) return "";
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const day = date.getDate();
  return `${year}年${month}月${day}日`;
}

// 随机恋爱格言
const loveQuotes = [
  "你是我一生只会遇见一次的惊喜",
  "有你的每一天，都是情人节",
  "世间万物，不及你眉眼半分",
  "想和你一起，看遍世间所有浪漫",
  "遇见你之后，我的世界有了光",
  "你是我的今天，也是我的明天",
  "爱不是相互凝望，而是一起朝同一个方向看",
  "我在人间贩卖黄昏，只为收集世间温柔去见你",
];
const todayQuote = loveQuotes[Math.floor(Math.random() * loveQuotes.length)];
---

<Base title="我们的恋爱日常" description="记录和你在一起的每一天 💕">
  <div class="home-page">
    <!-- 顶部大图区域 -->
    <header class="home-hero">
      <div class="home-hero-bg"></div>
      <div class="home-hero-stars" id="heroStars"></div>
      <div class="home-hero-content">
        <div class="home-hero-date">
          <span class="home-hero-day">{new Date().getDate()}</span>
          <span class="home-hero-month">{new Date().getMonth() + 1}月</span>
          <span class="home-hero-weekday">
            {["日", "一", "二", "三", "四", "五", "六"][new Date().getDay()]}曜日
          </span>
        </div>
        <h1 class="home-hero-title">
          <span class="home-hero-title-line">我们的</span>
          <span class="home-hero-title-line love-gradient-text">恋爱日常</span>
        </h1>
        <p class="home-hero-quote">“{todayQuote}”</p>
        <div class="home-hero-stats">
          <div class="home-hero-stat">
            <div class="home-hero-stat-number">{loveDays}</div>
            <div class="home-hero-stat-label">相恋天数</div>
          </div>
          <div class="home-hero-stat-heart">💗</div>
          <div class="home-hero-stat">
            <div class="home-hero-stat-number">{totalPosts}</div>
            <div class="home-hero-stat-label">甜蜜瞬间</div>
          </div>
        </div>
        <div class="home-hero-scroll">
          <span>向下滑动</span>
          <div class="home-hero-scroll-arrow">⌄</div>
        </div>
      </div>
    </header>

    <!-- 时间线日记 -->
    <main class="home-main">
      <div class="home-section-header">
        <h2 class="home-section-title">
          <span>📖</span> 我们的故事
        </h2>
        <p class="home-section-desc">每一个瞬间，都值得被珍藏</p>
      </div>

      {posts.length > 0 ? (
        <div class="home-diary-list">
          {posts.map((post, i) => {
            const previewContent = getPreviewContent(post.content);
            const moodDisplay = getMoodDisplay(post.excerpt);
            const dateStr = formatDate(post.publishedAt);
            const isEven = i % 2 === 0;

            return (
              <div class={`home-diary-card ${isEven ? "card-left" : "card-right"}`}>
                <div class="home-diary-card-inner">
                  {post.featuredImageKey && (
                    <div class="home-diary-card-image">
                      <img
                        src={`/media/${post.featuredImageKey}`}
                        alt={post.title}
                        loading="lazy"
                      />
                      <div class="home-diary-card-image-overlay"></div>
                    </div>
                  )}
                  <div class="home-diary-card-body">
                    <div class="home-diary-card-tags">
                      <span class="home-diary-card-mood">{moodDisplay}</span>
                      <span class="home-diary-card-number">#{totalPosts - i}</span>
                    </div>
                    <h3 class="home-diary-card-title">{post.title}</h3>
                    <p class="home-diary-card-excerpt">{previewContent}</p>
                    <div class="home-diary-card-footer">
                      <time class="home-diary-card-date">📅 {dateStr}</time>
                      <a href={`/home?article=${post.slug}`} class="home-diary-card-link">
                        阅读更多 →
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="home-empty">
          <div class="home-empty-icon">💌</div>
          <h3>还没有恋爱日记</h3>
          <p>快来这里记录你们的甜蜜日常吧~</p>
          <div class="home-empty-hearts">
            <span>💕</span><span>💗</span><span>💖</span><span>💝</span>
          </div>
        </div>
      )}

      {totalPages > 1 && (
        <div class="home-pagination">
          {page > 1 && (
            <a href={`/home?page=${page - 1}`} class="home-page-btn">
              ← 上一页
            </a>
          )}
          <span class="home-page-info">{page} / {totalPages}</span>
          {page < totalPages && (
            <a href={`/home?page=${page + 1}`} class="home-page-btn">
              下一页 →
            </a>
          )}
        </div>
      )}
    </main>

    <!-- 底部告白 -->
    <footer class="home-footer">
      <div class="home-footer-hearts">
        <span>❤️</span><span>💕</span><span>💗</span><span>💖</span><span>💝</span><span>❤️</span>
      </div>
      <p class="home-footer-text">JY先生 ❤️ JX女士</p>
      <p class="home-footer-sub">从 2026年3月21日 开始，一直爱下去</p>
    </footer>
  </div>

  <div id="heartContainer"></div>
</Base>

