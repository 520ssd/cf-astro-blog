---
export const prerender = false;

import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import { blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";

// 从 URL 查询参数中获取文章 slug
const articleSlug = Astro.url.searchParams.get("article");

if (!articleSlug) {
  return Astro.redirect("/home");
}

const db = getDb(env.DB);
const post = await db.query.blogPosts.findFirst({
  where: eq(blogPosts.slug, articleSlug),
});

if (!post) return Astro.redirect("/home");

const startDateStr = "2026-03-21";
function getLoveDays(startStr: string) {
  const start = new Date(startStr);
  const now = new Date();
  return Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
}
const loveDays = getLoveDays(startDateStr);
// ... 后续 HTML 模板保持不变 ...
